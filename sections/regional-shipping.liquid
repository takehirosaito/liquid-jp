{% comment %}
============================================================
セクション名: 地域別配送目安
用途: 注文後にお届けまで何日かかるかを地域別に一覧表示し、購入前の不安を解消する。商品ページや配送ガイドページで、関東・関西・九州・北海道など全国の目安日数を分かりやすく伝える。
推奨設置場所: 商品ページの下部、配送ガイドページ、ご利用ガイドページ、トップページのフッター上
カスタマイズポイント:
  - セクション見出し・補足テキスト
  - 出荷拠点の説明文(例: 東京都内の倉庫から出荷)
  - 地域ブロック(地域名・都道府県・目安日数・備考)
  - 背景色・アクセントカラー
  - 注意書き(離島・天候による遅延など)
注意点:
  - 目安日数は営業日ベースで記載することを推奨する
  - 北海道・沖縄・離島は別記載が望ましい(日本の EC 慣習)
  - 表示日数を変更したい場合はテーマエディタからブロック単位で編集可能
動作確認バージョン: Online Store 2.0
ライセンス: ALSEL Original
============================================================
{% endcomment %}

{%- assign sec_heading = section.settings.heading | escape -%}

<section class="alsel-regional-shipping" aria-label="{{ sec_heading }}">
  <div class="alsel-regional-shipping__inner">
    {%- if section.settings.heading != blank -%}
      <h2 class="alsel-regional-shipping__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    {%- if section.settings.lead != blank -%}
      <p class="alsel-regional-shipping__lead">{{ section.settings.lead }}</p>
    {%- endif -%}

    {%- if section.settings.warehouse_note != blank -%}
      <div class="alsel-regional-shipping__warehouse" role="note">
        <span class="alsel-regional-shipping__warehouse-icon" aria-hidden="true">📦</span>
        <span>{{ section.settings.warehouse_note }}</span>
      </div>
    {%- endif -%}

    {%- if section.blocks.size == 0 -%}
      <p class="alsel-regional-shipping__empty">
        現在表示できる配送地域はありません。テーマエディタからブロックを追加してください。
      </p>
    {%- else -%}
      <div class="alsel-regional-shipping__table" role="table" aria-label="地域別配送目安一覧">
        <div class="alsel-regional-shipping__thead" role="row">
          <div class="alsel-regional-shipping__th alsel-regional-shipping__th--region" role="columnheader">配送地域</div>
          <div class="alsel-regional-shipping__th alsel-regional-shipping__th--prefs" role="columnheader">対象の都道府県</div>
          <div class="alsel-regional-shipping__th alsel-regional-shipping__th--days" role="columnheader">お届け目安</div>
        </div>

        {%- for block in section.blocks -%}
          <div class="alsel-regional-shipping__row" role="row" {{ block.shopify_attributes }}>
            <div class="alsel-regional-shipping__cell alsel-regional-shipping__cell--region" role="cell">
              <span class="alsel-regional-shipping__badge" style="background: {{ block.settings.badge_color }};">
                {{ block.settings.region_name }}
              </span>
            </div>
            <div class="alsel-regional-shipping__cell alsel-regional-shipping__cell--prefs" role="cell">
              <span class="alsel-regional-shipping__label" aria-hidden="true">対象エリア:</span>
              {{ block.settings.prefectures }}
            </div>
            <div class="alsel-regional-shipping__cell alsel-regional-shipping__cell--days" role="cell">
              <span class="alsel-regional-shipping__label" aria-hidden="true">お届け目安:</span>
              <span class="alsel-regional-shipping__days">
                <strong>{{ block.settings.days }}</strong>
                <span class="alsel-regional-shipping__unit">{{ block.settings.unit }}</span>
              </span>
              {%- if block.settings.note != blank -%}
                <span class="alsel-regional-shipping__note">{{ block.settings.note }}</span>
              {%- endif -%}
            </div>
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- if section.settings.caution != blank -%}
      <div class="alsel-regional-shipping__caution" role="note">
        <p class="alsel-regional-shipping__caution-title">ご注意事項</p>
        <div class="alsel-regional-shipping__caution-body">{{ section.settings.caution }}</div>
      </div>
    {%- endif -%}
  </div>
</section>

<style>
  .alsel-regional-shipping {
    padding: 3rem 1rem;
    background: {{ section.settings.bg_color }};
    color: #1f2937;
  }
  .alsel-regional-shipping__inner { max-width: 960px; margin: 0 auto; }
  .alsel-regional-shipping__heading {
    font-size: clamp(1.4rem, 4vw, 2rem);
    font-weight: 700;
    text-align: center;
    margin: 0 0 1rem;
    color: {{ section.settings.accent_color }};
  }
  .alsel-regional-shipping__lead {
    text-align: center;
    font-size: 0.95rem;
    line-height: 1.7;
    margin: 0 0 1.5rem;
    color: #475569;
  }
  .alsel-regional-shipping__warehouse {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    justify-content: center;
    background: #fff;
    border: 1px dashed {{ section.settings.accent_color }};
    border-radius: 8px;
    padding: 0.75rem 1rem;
    font-size: 0.9rem;
    margin: 0 0 2rem;
    color: #334155;
  }
  .alsel-regional-shipping__warehouse-icon { font-size: 1.1rem; }
  .alsel-regional-shipping__empty {
    text-align: center;
    color: #888;
    padding: 2rem 0;
    background: #fff;
    border-radius: 8px;
  }
  .alsel-regional-shipping__table {
    background: #fff;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 2px 8px rgba(0,0,0,0.05);
  }
  .alsel-regional-shipping__thead { display: none; }
  .alsel-regional-shipping__row {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.5rem;
    padding: 1rem 1.25rem;
    border-bottom: 1px solid #e5e7eb;
  }
  .alsel-regional-shipping__row:last-child { border-bottom: 0; }
  .alsel-regional-shipping__cell {
    font-size: 0.95rem;
    line-height: 1.6;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
  }
  .alsel-regional-shipping__label {
    font-size: 0.8rem;
    color: #64748b;
    background: #f1f5f9;
    padding: 0.1rem 0.5rem;
    border-radius: 4px;
    font-weight: 600;
  }
  .alsel-regional-shipping__badge {
    display: inline-block;
    color: #fff;
    font-weight: 700;
    padding: 0.35rem 0.9rem;
    border-radius: 9999px;
    font-size: 0.9rem;
  }
  .alsel-regional-shipping__days {
    display: inline-flex;
    align-items: baseline;
    gap: 0.25rem;
    color: {{ section.settings.accent_color }};
  }
  .alsel-regional-shipping__days strong { font-size: 1.3rem; font-weight: 700; }
  .alsel-regional-shipping__unit { font-size: 0.9rem; color: #475569; font-weight: 500; }
  .alsel-regional-shipping__note {
    display: block;
    width: 100%;
    font-size: 0.8rem;
    color: #ef4444;
    margin-top: 0.25rem;
  }
  .alsel-regional-shipping__caution {
    margin-top: 1.5rem;
    background: #fef9c3;
    border-left: 4px solid #eab308;
    padding: 1rem 1.25rem;
    border-radius: 6px;
  }
  .alsel-regional-shipping__caution-title {
    font-weight: 700;
    margin: 0 0 0.5rem;
    color: #854d0e;
    font-size: 0.95rem;
  }
  .alsel-regional-shipping__caution-body {
    font-size: 0.85rem;
    line-height: 1.7;
    color: #713f12;
  }
  .alsel-regional-shipping__caution-body p { margin: 0 0 0.25rem; }
  @media (min-width: 750px) {
    .alsel-regional-shipping { padding: 4rem 2rem; }
    .alsel-regional-shipping__thead {
      display: grid;
      grid-template-columns: 180px 1fr 220px;
      background: {{ section.settings.accent_color }};
      color: #fff;
      font-weight: 700;
      font-size: 0.9rem;
    }
    .alsel-regional-shipping__th { padding: 0.85rem 1.25rem; }
    .alsel-regional-shipping__row {
      grid-template-columns: 180px 1fr 220px;
      gap: 1rem;
      align-items: center;
    }
    .alsel-regional-shipping__label { display: none; }
    .alsel-regional-shipping__cell--days { flex-direction: column; align-items: flex-start; gap: 0.25rem; }
  }
</style>

{% schema %}
{
  "name": "地域別配送目安",
  "tag": "section",
  "class": "alsel-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "セクション見出し",
      "default": "地域別のお届け目安"
    },
    {
      "type": "textarea",
      "id": "lead",
      "label": "補足テキスト",
      "default": "ご注文後の出荷から、お届けまでの日数の目安をご案内します。"
    },
    {
      "type": "text",
      "id": "warehouse_note",
      "label": "出荷拠点の説明",
      "info": "出荷元の倉庫所在地などを記載します",
      "default": "東京都内の倉庫から出荷いたします(平日 14:00 までのご注文は当日出荷)"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "背景色",
      "default": "#f8fafc"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "アクセントカラー",
      "default": "#0ea5e9"
    },
    {
      "type": "richtext",
      "id": "caution",
