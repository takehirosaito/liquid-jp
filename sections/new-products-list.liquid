{% comment %}
============================================================
セクション名: 新商品一覧
用途: 新着商品を「NEW」バッジ付きで一覧表示し、来店客の注目を新作に誘導する
推奨設置場所: トップページの中段(ヒーロー直下や特集セクションの後)、コレクションページの上部
カスタマイズポイント:
  - 表示するコレクション(通常は「新商品」コレクションを指定)
  - 見出しとサブテキスト
  - 表示する商品数(最大 12 件)
  - PC・モバイルの列数
  - NEW バッジの表示日数(発売日から何日以内を「新商品」とするか)
  - NEW バッジの文字・背景色
  - 価格・ベンダー表示の ON/OFF
注意点:
  - コレクション未選択時は「新商品コレクションを選んでください」と表示する
  - NEW バッジは商品の published_at(公開日)から判定する
  - 商品画像は自動で正方形にトリミングされる
動作確認バージョン: Online Store 2.0
ライセンス: ALSEL Original
============================================================
{% endcomment %}

<section class="alsel-new-products-list" aria-label="{{ section.settings.heading | escape }}">
  <div class="alsel-new-products-list__header">
    {%- if section.settings.heading != blank -%}
      <h2 class="alsel-new-products-list__title">{{ section.settings.heading }}</h2>
    {%- endif -%}
    {%- if section.settings.subheading != blank -%}
      <p class="alsel-new-products-list__sub">{{ section.settings.subheading }}</p>
    {%- endif -%}
  </div>

  {%- assign coll = collections[section.settings.collection] -%}
  {%- if coll != blank and coll.products.size > 0 -%}
    <div class="alsel-new-products-list__grid">
      {%- assign limit = section.settings.product_limit | times: 1 -%}
      {%- assign new_days = section.settings.new_days | times: 1 -%}
      {%- assign now_ts = 'now' | date: '%s' | times: 1 -%}
      {%- assign threshold = new_days | times: 86400 -%}
      {%- for product in coll.products limit: limit -%}
        {%- assign pub_ts = product.published_at | date: '%s' | times: 1 -%}
        {%- assign diff = now_ts | minus: pub_ts -%}
        <a class="alsel-new-products-list__card" href="{{ product.url }}" aria-label="{{ product.title | escape }}">
          <div class="alsel-new-products-list__media">
            {%- if diff <= threshold -%}
              <span class="alsel-new-products-list__badge" aria-label="新商品">{{ section.settings.badge_text }}</span>
            {%- endif -%}
            {%- if product.featured_image != blank -%}
              {%- assign alt_1 = product.title | escape -%}
{{ product.featured_image
                | image_url: width: 800
                | image_tag: loading: 'lazy', class: 'alsel-new-products-list__img', alt: alt_1, widths: '300, 500, 700, 800', sizes: '(min-width: 750px) 25vw, 50vw' }}
            {%- else -%}
              <div class="alsel-new-products-list__noimg" aria-hidden="true">No Image</div>
            {%- endif -%}
          </div>
          <div class="alsel-new-products-list__info">
            {%- if section.settings.show_vendor and product.vendor != blank -%}
              <p class="alsel-new-products-list__vendor">{{ product.vendor | escape }}</p>
            {%- endif -%}
            <h3 class="alsel-new-products-list__name">{{ product.title | escape }}</h3>
            {%- if section.settings.show_price -%}
              <p class="alsel-new-products-list__price">
                {%- if product.compare_at_price > product.price -%}
                  <span class="alsel-new-products-list__price-sale">{{ product.price | money }}</span>
                  <span class="alsel-new-products-list__price-old">{{ product.compare_at_price | money }}</span>
                {%- else -%}
                  <span>{{ product.price | money }}</span>
                {%- endif -%}
              </p>
            {%- endif -%}
          </div>
        </a>
      {%- endfor -%}
    </div>
  {%- else -%}
    <p class="alsel-new-products-list__empty">テーマエディタからコレクションを選択すると、新商品が一覧表示されます。</p>
  {%- endif -%}
</section>

<style>
  .alsel-new-products-list {
    padding: 3rem 1rem;
    background: {{ section.settings.bg_color }};
    color: {{ section.settings.text_color }};
  }
  .alsel-new-products-list__header { text-align: center; margin: 0 auto 2rem; max-width: 720px; }
  .alsel-new-products-list__title { font-size: clamp(1.5rem, 4vw, 2.2rem); font-weight: 700; margin: 0 0 0.5rem; letter-spacing: 0.02em; }
  .alsel-new-products-list__sub { font-size: 0.95rem; line-height: 1.7; margin: 0; opacity: 0.8; }
  .alsel-new-products-list__grid {
    display: grid;
    grid-template-columns: repeat({{ section.settings.cols_mobile }}, 1fr);
    gap: 1rem;
    max-width: 1200px;
    margin: 0 auto;
  }
  .alsel-new-products-list__card {
    display: block;
    text-decoration: none;
    color: inherit;
    background: #fff;
    border-radius: 10px;
    overflow: hidden;
    box-shadow: 0 1px 4px rgba(0,0,0,0.06);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  .alsel-new-products-list__card:hover { transform: translateY(-4px); box-shadow: 0 6px 16px rgba(0,0,0,0.1); }
  .alsel-new-products-list__media { position: relative; aspect-ratio: 1 / 1; overflow: hidden; background: #f1f5f9; }
  .alsel-new-products-list__img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .alsel-new-products-list__noimg { width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; color: #94a3b8; font-size: 0.9rem; }
  .alsel-new-products-list__badge {
    position: absolute;
    top: 0.6rem;
    left: 0.6rem;
    background: {{ section.settings.badge_bg }};
    color: {{ section.settings.badge_color }};
    font-size: 0.72rem;
    font-weight: 700;
    padding: 0.25rem 0.6rem;
    border-radius: 4px;
    letter-spacing: 0.05em;
    z-index: 1;
  }
  .alsel-new-products-list__info { padding: 0.8rem; }
  .alsel-new-products-list__vendor { font-size: 0.75rem; opacity: 0.6; margin: 0 0 0.25rem; }
  .alsel-new-products-list__name { font-size: 0.9rem; line-height: 1.5; font-weight: 600; margin: 0 0 0.5rem; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
  .alsel-new-products-list__price { font-size: 0.95rem; font-weight: 700; margin: 0; }
  .alsel-new-products-list__price-sale { color: #dc2626; margin-right: 0.4rem; }
  .alsel-new-products-list__price-old { font-weight: 400; font-size: 0.85rem; text-decoration: line-through; opacity: 0.6; }
  .alsel-new-products-list__empty { text-align: center; padding: 2rem; color: #64748b; }
  @media (min-width: 750px) {
    .alsel-new-products-list { padding: 5rem 2rem; }
    .alsel-new-products-list__grid { grid-template-columns: repeat({{ section.settings.cols_desktop }}, 1fr); gap: 1.5rem; }
    .alsel-new-products-list__info { padding: 1rem; }
    .alsel-new-products-list__name { font-size: 0.95rem; }
  }
</style>

{% schema %}
{
  "name": "新商品一覧",
  "tag": "section",
  "class": "alsel-section",
  "settings": [
    { "type": "header", "content": "コンテンツ設定" },
    { "type": "text", "id": "heading", "label": "見出し", "default": "新商品" },
    { "type": "text", "id": "subheading", "label": "サブテキスト", "default": "最新の入荷アイテムをご紹介します。" },
    { "type": "collection", "id": "collection", "label": "表示するコレクション", "info": "通常は「新商品」コレクションを指定する" },
    { "type": "range", "id": "product_limit", "label": "表示する商品数", "min": 2, "max": 12, "step": 1, "default": 8 },
    { "type": "header", "content": "NEW バッジ設定" },
    { "type": "text", "id": "badge_text", "label": "バッジの文字", "default": "NEW" },
    { "type": "range", "id": "new_days", "label": "NEW と表示する日数", "min": 7, "max": 90, "step": 1, "default": 30, "unit": "日", "info": "商品の公開日から指定日数以内のものに NEW バッジを表示する" },
    { "type": "color", "id": "badge_bg", "label": "バッジ背景色", "default": "#dc2626" },
    { "type": "color", "id": "badge_color", "label": "バッジ文字色", "default": "#ffffff" },
    { "type": "header", "content": "表示オプション" },
    { "type": "checkbox", "id": "show_vendor", "label": "ブランド名を表示する", "default": false },
    { "type": "checkbox", "id": "show_price", "label": "価格を表示する", "default": true },
    { "type": "header", "content": "レイアウト" },
    { "type": "select", "id": "cols_mobile", "label": "モバイルの列数",
      "options": [
        { "value": "1", "label": "1列" },
        { "value": "2", "label": "2列" }
      ],
      "default": "2" },
    { "type": "select", "id": "cols_desktop", "label": "PC の列数",
      "options": [
        { "value": "3", "label": "3列" },
        { "value": "4", "label": "4列" },
        { "value": "5", "label": "5列" }
      ],
      "default": "4" },
    { "type": "header", "content": "配色" },
    { "type": "color", "id": "bg_color", "label": "背景色", "default": "#ffffff" },
    { "type": "color", "id": "text_color", "label": "文字色", "default": "#0f172a" }
  ],
  "presets": [
    {
      "name": "ALSEL監修 / 新商品一覧",
      "settings": {
        "heading": "新商品",
        "subheading": "最新の入荷アイテムをご紹介します。",
        "product_limit": 8,
        "badge_text": "NEW",
        "new_days": 30,
        "show_price": true,
        "cols_mobile": "2",
        "cols_desktop": "4"
      }
    }
  ]
}
{% endschema %}