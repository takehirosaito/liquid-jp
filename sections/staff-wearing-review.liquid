{% comment %}
============================================================
セクション名: スタッフ着用レビュー
用途: アパレル商品の着用イメージを、スタッフの身長・体型・着用サイズと共に伝えるアパレル特化セクション
推奨設置場所: 商品ページの商品情報下、トップページのカテゴリ訴求エリア
カスタマイズポイント:
  - セクション見出し・サブコピー・背景色
  - スタッフブロックごとの着用画像
  - スタッフ名・身長・体型・通常サイズ・着用サイズ
  - レビューコメント
  - スタッフ情報の表示形式(背景色・アクセントカラー)
注意点:
  - 着用画像は縦長(推奨 800 × 1200px、JPEG)を推奨します
  - スタッフブロックは 2〜6 件で最適化されます
  - ブロックが 0 件の場合は空フォールバックを表示します
動作確認バージョン: Online Store 2.0
ライセンス: ALSEL Original
============================================================
{% endcomment %}

{%- assign heading_alt = section.settings.heading | escape -%}

<section class="alsel-staff-wearing-review" aria-label="{{ heading_alt }}">
  <div class="alsel-staff-wearing-review__head">
    {%- if section.settings.heading != blank -%}
      <h2 class="alsel-staff-wearing-review__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}
    {%- if section.settings.subheading != blank -%}
      <p class="alsel-staff-wearing-review__sub">{{ section.settings.subheading }}</p>
    {%- endif -%}
  </div>

  {%- if section.blocks.size == 0 -%}
    <p class="alsel-staff-wearing-review__empty">
      スタッフ着用レビューはまだ登録されていません。テーマエディタからブロックを追加してください。
    </p>
  {%- else -%}
    <div class="alsel-staff-wearing-review__grid">
      {%- for block in section.blocks -%}
        {%- assign staff_alt = block.settings.staff_name | append: 'の着用イメージ' | escape -%}
        <article class="alsel-staff-wearing-review__card" {{ block.shopify_attributes }}>
          <div class="alsel-staff-wearing-review__media">
            {%- if block.settings.staff_image != blank -%}
              {{ block.settings.staff_image
                | image_url: width: 800
                | image_tag: loading: 'lazy', class: 'alsel-staff-wearing-review__img', alt: staff_alt, widths: '375, 600, 800' }}
            {%- else -%}
              <div class="alsel-staff-wearing-review__noimg" aria-hidden="true">No Image</div>
            {%- endif -%}
            {%- if block.settings.wearing_size != blank -%}
              <span class="alsel-staff-wearing-review__badge">着用サイズ {{ block.settings.wearing_size }}</span>
            {%- endif -%}
          </div>
          <div class="alsel-staff-wearing-review__body">
            {%- if block.settings.staff_name != blank -%}
              <h3 class="alsel-staff-wearing-review__name">
                {{ block.settings.staff_name }}
                {%- if block.settings.staff_role != blank -%}
                  <span class="alsel-staff-wearing-review__role">/ {{ block.settings.staff_role }}</span>
                {%- endif -%}
              </h3>
            {%- endif -%}

            <dl class="alsel-staff-wearing-review__specs">
              {%- if block.settings.height != blank -%}
                <div class="alsel-staff-wearing-review__spec">
                  <dt>身長</dt><dd>{{ block.settings.height }}</dd>
                </div>
              {%- endif -%}
              {%- if block.settings.body_type != blank -%}
                <div class="alsel-staff-wearing-review__spec">
                  <dt>体型</dt><dd>{{ block.settings.body_type }}</dd>
                </div>
              {%- endif -%}
              {%- if block.settings.usual_size != blank -%}
                <div class="alsel-staff-wearing-review__spec">
                  <dt>通常サイズ</dt><dd>{{ block.settings.usual_size }}</dd>
                </div>
              {%- endif -%}
              {%- if block.settings.wearing_size != blank -%}
                <div class="alsel-staff-wearing-review__spec alsel-staff-wearing-review__spec--accent">
                  <dt>着用サイズ</dt><dd>{{ block.settings.wearing_size }}</dd>
                </div>
              {%- endif -%}
            </dl>

            {%- if block.settings.comment != blank -%}
              <p class="alsel-staff-wearing-review__comment">{{ block.settings.comment }}</p>
            {%- endif -%}
          </div>
        </article>
      {%- endfor -%}
    </div>
  {%- endif -%}
</section>

<style>
  .alsel-staff-wearing-review { padding: 3rem 1rem; background: {{ section.settings.bg_color }}; color: {{ section.settings.text_color }}; }
  .alsel-staff-wearing-review__head { text-align: center; max-width: 800px; margin: 0 auto 2rem; }
  .alsel-staff-wearing-review__heading { font-size: clamp(1.4rem, 4vw, 2.2rem); font-weight: 700; margin: 0 0 0.75rem; line-height: 1.4; }
  .alsel-staff-wearing-review__sub { font-size: 0.95rem; line-height: 1.7; margin: 0; opacity: 0.8; }
  .alsel-staff-wearing-review__empty { text-align: center; color: #888; padding: 2rem 0; margin: 0; }
  .alsel-staff-wearing-review__grid { display: grid; grid-template-columns: 1fr; gap: 1.5rem; max-width: 1200px; margin: 0 auto; }
  .alsel-staff-wearing-review__card { background: #fff; border-radius: 14px; overflow: hidden; box-shadow: 0 4px 16px rgba(0,0,0,0.06); display: flex; flex-direction: column; }
  .alsel-staff-wearing-review__media { position: relative; aspect-ratio: 2 / 3; overflow: hidden; background: #f1f5f9; }
  .alsel-staff-wearing-review__img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .alsel-staff-wearing-review__noimg { display: flex; align-items: center; justify-content: center; width: 100%; height: 100%; color: #94a3b8; font-size: 0.9rem; letter-spacing: 0.1em; }
  .alsel-staff-wearing-review__badge { position: absolute; left: 0.75rem; bottom: 0.75rem; background: {{ section.settings.accent_color }}; color: #fff; font-size: 0.8rem; font-weight: 700; padding: 0.35rem 0.75rem; border-radius: 9999px; }
  .alsel-staff-wearing-review__body { padding: 1.25rem; color: #1f2937; display: flex; flex-direction: column; gap: 0.85rem; }
  .alsel-staff-wearing-review__name { font-size: 1.05rem; font-weight: 700; margin: 0; line-height: 1.4; }
  .alsel-staff-wearing-review__role { font-size: 0.85rem; font-weight: 500; color: #64748b; margin-left: 0.25rem; }
  .alsel-staff-wearing-review__specs { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; margin: 0; padding: 0.85rem; background: #f8fafc; border-radius: 8px; }
  .alsel-staff-wearing-review__spec { display: flex; flex-direction: column; gap: 0.15rem; }
  .alsel-staff-wearing-review__spec dt { font-size: 0.72rem; color: #64748b; margin: 0; }
  .alsel-staff-wearing-review__spec dd { font-size: 0.95rem; font-weight: 700; color: #1f2937; margin: 0; }
  .alsel-staff-wearing-review__spec--accent dd { color: {{ section.settings.accent_color }}; }
  .alsel-staff-wearing-review__comment { font-size: 0.9rem; line-height: 1.7; color: #475569; margin: 0; padding: 0.5rem 0 0; border-top: 1px dashed #e2e8f0; }
  @media (min-width: 750px) {
    .alsel-staff-wearing-review { padding: 5rem 2rem; }
    .alsel-staff-wearing-review__grid { grid-template-columns: repeat(2, 1fr); gap: 2rem; }
    .alsel-staff-wearing-review__body { padding: 1.5rem; }
  }
  @media (min-width: 1024px) {
    .alsel-staff-wearing-review__grid { grid-template-columns: repeat(3, 1fr); }
  }
</style>

{% schema %}
{
  "name": "スタッフ着用レビュー",
  "tag": "section",
  "class": "alsel-section",
  "settings": [
    { "type": "text", "id": "heading", "label": "セクション見出し", "default": "スタッフ着用レビュー" },
    { "type": "textarea", "id": "subheading", "label": "サブコピー", "default": "身長・体型の異なるスタッフが実際に着用した感想をご紹介します。サイズ選びの参考にしてください。" },
    { "type": "color", "id": "bg_color", "label": "背景色", "default": "#f8fafc" },
    { "type": "color", "id": "text_color", "label": "見出し・サブコピーの文字色", "default": "#1f2937" },
    { "type": "color", "id": "accent_color", "label": "アクセントカラー(着用サイズ・バッジ)", "default": "#d97706", "info": "着用サイズの文字色とバッジ背景に使用されます。" }
  ],
  "blocks": [
    {
      "type": "staff",
      "name": "スタッフ",
      "settings": [
        { "type": "image_picker", "id": "staff_image", "label": "着用画像", "info": "推奨 800 × 1200px の縦長画像、JPEG または PNG" },
        { "type": "text", "id": "staff_name", "label": "スタッフ名", "default": "スタッフ A" },
        { "type": "text", "id": "staff_role", "label": "肩書き・部署(任意)", "default": "店舗スタッフ" },
        { "type": "text", "id": "height", "label": "身長", "default": "165cm", "info": "例: 165cm" },
        { "type": "text", "id": "body_type", "label": "体型", "default": "標準体型", "info": "例: 標準体型 / 細身 / がっちり" },
        { "type": "text", "id": "usual_size", "label": "通常サイズ", "default": "M", "info": "普段着用しているサイズ" },
        { "type": "text", "id": "wearing_size", "label": "着用サイズ", "default": "M", "info": "本商品で着用しているサイズ" },
        { "type": "textarea", "id": "comment", "label": "着用コメント", "default": "ジャストサイズで着用しました。袖丈・着丈ともにちょうど良く、普段着としてもきれいめにも合わせられます。" }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "ALSEL監修 / スタッフ着用レビュー(カードグリッド)",
      "settings": {
        "heading": "スタッフ着用レビュー(カードグリッド)",
        "subheading": "身長・体型の異なるスタッフが実際に着用した感想をご紹介します。サイズ選びの参考にしてください。"
      },
      "blocks": [
        {
          "type": "staff",
          "settings": {
            "staff_name": "スタッフ A",
            "staff_role": "店舗スタッフ",
            "height": "158cm",
            "body_type": "細身",
            "usual_size": "S",
            "wearing_size": "S",
            "comment": "ジャストサイズで着用しました。コンパクトに見えてスタイルアップが叶います。"
          }
        },
        {
          "type": "staff",
          "settings": {
            "staff_name": "スタッフ B",
            "staff_role": "バイヤー",
            "height": "168cm",
            "body_type": "標準体型",
            "usual_size": "M",
            "wearing_size": "M",
            "comment": "肩幅・着丈ともにバランス良く、毎日のコーディネートに取り入れやすい一着です。"
          }
        },
        {
          "type": "staff",
          "settings": {
            "staff_name": "スタッフ C",
            "staff_role": "ディレクター",
            "height": "175cm",
            "body_type": "がっちり",
            "usual_size": "L",
            "wearing_size": "XL",
            "comment": "ワンサイズアップでゆったり着用しました。リラックス感のあるシルエットを楽しめます。"
          }
        }
      ]
    }
  ]
}
{% endschema %}