{% comment %}
============================================================
セクション名: 返品交換ガイド
用途: 返品・交換の条件や手順をわかりやすく整理して、購入前の不安を解消するためのセクション。初心者店舗の信頼感アップに有効。
推奨設置場所: 商品ページの下部・特定商取引法ページ・FAQ ページ・トップページの下部
カスタマイズポイント:
  - セクション見出し・リード文
  - 受付期間や条件などの「ポイントカード」(アイコン + タイトル + 説明)
  - 返品交換の流れ(ステップ形式、ブロック追加で増減可能)
  - 注意事項リスト
  - 問い合わせボタン(リンク先・文字)
  - 背景色・アクセントカラー
注意点:
  - アイコンは絵文字ベース(画像不要)で実装し、初心者でもすぐ使えるようにしている
  - ブロックは「ポイント」「ステップ」「注意事項」の 3 種類
  - Online Store 2.0 必須(blocks / presets 仕様)
動作確認バージョン: Online Store 2.0
ライセンス: ALSEL Original
============================================================
{% endcomment %}

<section class="alsel-returns-guide" aria-label="{{ section.settings.heading | escape }}">
  <div class="alsel-returns-guide__inner">

    {%- if section.settings.heading != blank -%}
      <h2 class="alsel-returns-guide__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    {%- if section.settings.lead != blank -%}
      <p class="alsel-returns-guide__lead">{{ section.settings.lead }}</p>
    {%- endif -%}

    {%- assign points = section.blocks | where: 'type', 'point' -%}
    {%- assign steps = section.blocks | where: 'type', 'step' -%}
    {%- assign notes = section.blocks | where: 'type', 'note' -%}

    {%- if section.blocks.size == 0 -%}
      <p class="alsel-returns-guide__empty">
        返品交換ガイドの項目はまだ登録されていません。テーマエディタからブロックを追加してください。
      </p>
    {%- endif -%}

    {%- if points.size > 0 -%}
      <div class="alsel-returns-guide__points">
        {%- for block in points -%}
          <div class="alsel-returns-guide__point" {{ block.shopify_attributes }}>
            <span class="alsel-returns-guide__point-icon" aria-hidden="true">{{ block.settings.icon }}</span>
            <h3 class="alsel-returns-guide__point-title">{{ block.settings.title }}</h3>
            <p class="alsel-returns-guide__point-body">{{ block.settings.body }}</p>
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- if steps.size > 0 -%}
      <div class="alsel-returns-guide__steps-wrap">
        {%- if section.settings.steps_heading != blank -%}
          <h3 class="alsel-returns-guide__sub-heading">{{ section.settings.steps_heading }}</h3>
        {%- endif -%}
        <ol class="alsel-returns-guide__steps">
          {%- for block in steps -%}
            <li class="alsel-returns-guide__step" {{ block.shopify_attributes }}>
              <span class="alsel-returns-guide__step-num" aria-hidden="true">{{ forloop.index }}</span>
              <div class="alsel-returns-guide__step-body">
                <h4 class="alsel-returns-guide__step-title">{{ block.settings.title }}</h4>
                <p class="alsel-returns-guide__step-text">{{ block.settings.body }}</p>
              </div>
            </li>
          {%- endfor -%}
        </ol>
      </div>
    {%- endif -%}

    {%- if notes.size > 0 -%}
      <div class="alsel-returns-guide__notes-wrap">
        {%- if section.settings.notes_heading != blank -%}
          <h3 class="alsel-returns-guide__sub-heading">{{ section.settings.notes_heading }}</h3>
        {%- endif -%}
        <ul class="alsel-returns-guide__notes">
          {%- for block in notes -%}
            <li class="alsel-returns-guide__note" {{ block.shopify_attributes }}>{{ block.settings.text }}</li>
          {%- endfor -%}
        </ul>
      </div>
    {%- endif -%}

    {%- if section.settings.cta_text != blank and section.settings.cta_link != blank -%}
      <div class="alsel-returns-guide__cta-wrap">
        <a class="alsel-returns-guide__cta" href="{{ section.settings.cta_link }}" aria-label="{{ section.settings.cta_text | escape }}">
          {{ section.settings.cta_text }}
        </a>
      </div>
    {%- endif -%}

  </div>
</section>

<style>
  .alsel-returns-guide {
    --arg-accent: {{ section.settings.accent_color }};
    --arg-bg: {{ section.settings.bg_color }};
    --arg-card: #ffffff;
    --arg-text: #1f2937;
    --arg-muted: #64748b;
    background: var(--arg-bg);
    padding: 3rem 1rem;
    color: var(--arg-text);
  }
  .alsel-returns-guide__inner { max-width: 1080px; margin: 0 auto; }
  .alsel-returns-guide__heading { font-size: clamp(1.5rem, 4vw, 2.2rem); font-weight: 700; text-align: center; margin: 0 0 0.75rem; }
  .alsel-returns-guide__lead { text-align: center; color: var(--arg-muted); line-height: 1.8; margin: 0 0 2.5rem; font-size: 0.95rem; }
  .alsel-returns-guide__empty { text-align: center; color: #888; padding: 2rem 0; }

  .alsel-returns-guide__points { display: grid; grid-template-columns: 1fr; gap: 1rem; margin-bottom: 2.5rem; }
  .alsel-returns-guide__point { background: var(--arg-card); border-radius: 12px; padding: 1.5rem 1.25rem; text-align: center; box-shadow: 0 2px 8px rgba(0,0,0,0.05); border-top: 4px solid var(--arg-accent); }
  .alsel-returns-guide__point-icon { display: inline-block; font-size: 2.2rem; margin-bottom: 0.5rem; }
  .alsel-returns-guide__point-title { font-size: 1.05rem; font-weight: 700; margin: 0 0 0.5rem; color: var(--arg-text); }
  .alsel-returns-guide__point-body { font-size: 0.9rem; line-height: 1.7; color: var(--arg-muted); margin: 0; }

  .alsel-returns-guide__sub-heading { font-size: 1.2rem; font-weight: 700; margin: 0 0 1.25rem; padding-left: 0.75rem; border-left: 4px solid var(--arg-accent); }

  .alsel-returns-guide__steps-wrap { margin-bottom: 2.5rem; }
  .alsel-returns-guide__steps { list-style: none; padding: 0; margin: 0; display: grid; gap: 1rem; }
  .alsel-returns-guide__step { display: flex; align-items: flex-start; gap: 1rem; background: var(--arg-card); border-radius: 12px; padding: 1.25rem; box-shadow: 0 2px 6px rgba(0,0,0,0.04); }
  .alsel-returns-guide__step-num { flex-shrink: 0; width: 36px; height: 36px; border-radius: 50%; background: var(--arg-accent); color: #fff; font-weight: 700; display: inline-flex; align-items: center; justify-content: center; font-size: 1rem; }
  .alsel-returns-guide__step-body { flex: 1; }
  .alsel-returns-guide__step-title { font-size: 1rem; font-weight: 700; margin: 0 0 0.4rem; }
  .alsel-returns-guide__step-text { font-size: 0.9rem; line-height: 1.7; color: var(--arg-muted); margin: 0; }

  .alsel-returns-guide__notes-wrap { background: #fff7ed; border-radius: 12px; padding: 1.5rem 1.25rem; margin-bottom: 2rem; }
  .alsel-returns-guide__notes-wrap .alsel-returns-guide__sub-heading { border-left-color: #f97316; }
  .alsel-returns-guide__notes { list-style: none; padding: 0; margin: 0; }
  .alsel-returns-guide__note { position: relative; padding-left: 1.5rem; font-size: 0.9rem; line-height: 1.8; color: #7c2d12; }
  .alsel-returns-guide__note + .alsel-returns-guide__note { margin-top: 0.5rem; }
  .alsel-returns-guide__note::before { content: "！"; position: absolute; left: 0; top: 0; color: #f97316; font-weight: 700; }

  .alsel-returns-guide__cta-wrap { text-align: center; margin-top: 2rem; }
  .alsel-returns-guide__cta { display: inline-block; padding: 0.95rem 2.25rem; background: var(--arg-accent); color: #fff; text-decoration: none; border-radius: 9999px; font-weight: 700; font-size: 0.95rem; transition: opacity 0.2s; }
  .alsel-returns-guide__cta:hover { opacity: 0.85; }

  @media (min-width: 750px) {
    .alsel-returns-guide { padding: 5rem 2rem; }
    .alsel-returns-guide__points { grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }
    .alsel-returns-guide__step { padding: 1.5rem 1.75rem; gap: 1.25rem; }
    .alsel-returns-guide__step-num { width: 42px; height: 42px; font-size: 1.1rem; }
  }
</style>

{% schema %}
{
  "name": "返品交換ガイド",
  "tag": "section",
  "class": "alsel-section",
  "settings": [
    { "type": "text", "id": "heading", "label": "セクション見出し", "default": "返品・交換について" },
    { "type": "textarea", "id": "lead", "label": "リード文", "default": "ご購入いただいた商品に万一の不備があった場合や、サイズが合わなかった場合の返品・交換について、わかりやすくご案内いたします。" },
    { "type": "header", "content": "見出し設定" },
    { "type": "text", "id": "steps_heading", "label": "ステップセクションの見出し", "default": "返品・交換の流れ" },
    { "type": "text", "id": "notes_heading", "label": "注意事項セクションの見出し", "default": "ご利用前にご確認ください" },
    { "type": "header", "content": "お問い合わせボタン" },
    { "type": "text", "id": "cta_text", "label": "ボタンの文字", "default": "お問い合わせはこちら" },
    { "type": "url", "id": "cta_link", "label": "ボタンのリンク先" },
    { "type": "header", "content": "デザイン設定" },
    { "type": "color", "id": "bg_color", "label": "背景色", "default": "#f8fafc" },
    { "type": "color", "id": "accent_color", "label": "アクセントカラー", "default": "#0ea5e9", "info": "見出しの帯やボタン、ステップ番号に使われます" }
  ],
  "blocks": [
    {
      "type": "point",
      "name": "ポイントカード",
      "limit": 6,
      "settings": [
        { "type": "text", "id": "icon", "label": "アイコン(絵文字)", "default": "📦", "info": "絵文字をそのまま入力してください(例: 📦 🔄 💳 ⏰)" },
        { "type": "text", "id": "title", "label": "タイトル", "default": "受付期間" },
        { "type": "textarea", "id": "body", "label": "説明文", "default": "ここに条件の詳細を記載します。" }
      ]
    },
    {
      "type": "step",
      "name": "ステップ(返品の流れ)",
      "settings": [
        { "type": "text", "id": "title", "label": "ステップのタイトル", "default": "ステップタイトル" },
        { "type": "textarea", "id": "body", "label": "ステップの説明", "default": "ここに手順の詳細を記載します。" }
      ]
    },
    {
      "type": "note",
      "name": "注意事項",
      "settings": [
        { "type": "textarea", "id": "text", "label": "注意事項の本文", "default": "注意事項の内容をここに記載します。" }
      ]
    }
  ],
  "presets": [
    {
      "name": "ALSEL監修 / 返品交換ガイド(ポイント+ステップ型)",
      "settings": {
        "heading": "返品・交換について",
        "lead": "ご購入いただいた商品に万一の不備があった場合や、サイズが合わなかった場合の返品・交換について、わかりやすくご案内いたします。",
        "steps_heading": "返品・交換の流れ",
        "notes_heading": "ご利用前にご確認ください",
        "cta_text": "お問い合わせはこちら"
      },
      "blocks": [
        { "type": "point", "settings": { "icon": "⏰", "title": "受付期間", "body": "商品到着後 7 日以内にご連絡をお願いいたします。" } },
        { "type": "point", "settings": { "icon": "📦", "title": "返品条件", "body": "未使用・未開封の商品に限り、返品をお受けいたします。" } },
        { "type": "point", "settings": { "icon": "💳", "title": "返金方法", "body": "ご購入時のお支払い方法に応じて返金処理を行います。" } },
        { "type": "step", "settings": { "title": "お問い合わせフォームよりご連絡", "body": "ご注文番号と返品理由を添えて、お問い合わせフォームからご連絡ください。" } },
        { "type": "step", "settings": { "title": "返送先のご案内をお送りします", "body": "弊社より返送先住所と手続き方法をメールでお送りいたします。" } },
        { "type": "step", "settings": { "title": "商品をご返送ください", "body": "商品を梱包のうえ、ご案内した住所までご返送をお願いいたします。" } },
        { "type": "step", "settings": { "title": "返金または交換品の発送", "body": "商品到着後、内容を確認のうえ返金または交換品の発送を行います。" } },
        { "type": "note", "settings": { "text": "お客様のご都合による返品の場合、送料はお客様負担となります。" } },
        { "type": "note", "settings": { "text": "セール品・受注生産品は返品交換の対象外となります。あらかじめご了承ください。" } },
        { "type": "note", "settings": { "text": "商品到着後 8 日以上経過した場合は、原則として返品をお受けできません。" } }
      ]
    }
  ]
}
{% endschema %}