{% comment %}
============================================================
セクション名: アパレルLOOKBOOK
用途: アパレルブランドのコーディネート提案をモデル画像で大きく見せる、ビジュアル訴求型のショーケース
推奨設置場所: トップページ・コレクションページ・LP の中盤(ブランドストーリー直後など)
カスタマイズポイント:
  - セクション見出し・サブコピー
  - モデル画像(ブロックごとに 1 枚)
  - 各画像のタイトル(コーデ名)・キャプション・リンク先
  - 背景色・文字色
  - レイアウト(2 カラム / 3 カラム)
  - ブロックの追加・削除でルック数を変更
注意点:
  - 画像はモデル全身が映る縦長(推奨 1200 × 1600px、3:4 比)を推奨
  - ブロックは 2〜12 個推奨。それ以上は表示パフォーマンスに影響する場合あり
  - リンク先は商品ページ・コレクションページのいずれでも設定可能
動作確認バージョン: Online Store 2.0
ライセンス: ALSEL Original
============================================================
{% endcomment %}

{%- assign heading_safe = section.settings.heading | escape -%}

<section class="alsel-lookbook" aria-label="{{ heading_safe }}">
  <div class="alsel-lookbook__header">
    {%- if section.settings.heading != blank -%}
      <h2 class="alsel-lookbook__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}
    {%- if section.settings.subheading != blank -%}
      <p class="alsel-lookbook__sub">{{ section.settings.subheading }}</p>
    {%- endif -%}
  </div>

  {%- if section.blocks.size == 0 -%}
    <p class="alsel-lookbook__empty">
      表示できるルックはまだ登録されていません。テーマエディタからブロックを追加してください。
    </p>
  {%- else -%}
    <div class="alsel-lookbook__grid alsel-lookbook__grid--cols-{{ section.settings.columns }}">
      {%- for block in section.blocks -%}
        {%- assign look_alt = block.settings.title | default: heading_safe | escape -%}
        {%- assign tag = 'div' -%}
        {%- if block.settings.link != blank -%}
          {%- assign tag = 'a' -%}
        {%- endif -%}
        <{{ tag }}
          class="alsel-lookbook__item"
          {% if block.settings.link != blank %}href="{{ block.settings.link }}" aria-label="{{ look_alt }}のページへ"{% endif %}
          {{ block.shopify_attributes }}
        >
          <figure class="alsel-lookbook__figure">
            {%- if block.settings.image != blank -%}
              {{ block.settings.image
                | image_url: width: 1200
                | image_tag:
                  loading: 'lazy',
                  class: 'alsel-lookbook__image',
                  alt: look_alt,
                  widths: '375, 600, 800, 1000, 1200',
                  sizes: '(min-width: 750px) 50vw, 100vw' }}
            {%- else -%}
              <div class="alsel-lookbook__placeholder" aria-hidden="true">IMAGE</div>
            {%- endif -%}
            {%- if block.settings.badge != blank -%}
              <span class="alsel-lookbook__badge">{{ block.settings.badge }}</span>
            {%- endif -%}
          </figure>
          {%- if block.settings.title != blank or block.settings.caption != blank -%}
            <figcaption class="alsel-lookbook__caption">
              {%- if block.settings.title != blank -%}
                <h3 class="alsel-lookbook__title">{{ block.settings.title }}</h3>
              {%- endif -%}
              {%- if block.settings.caption != blank -%}
                <p class="alsel-lookbook__text">{{ block.settings.caption }}</p>
              {%- endif -%}
              {%- if block.settings.link != blank and block.settings.link_text != blank -%}
                <span class="alsel-lookbook__more">{{ block.settings.link_text }}<span aria-hidden="true"> →</span></span>
              {%- endif -%}
            </figcaption>
          {%- endif -%}
        </{{ tag }}>
      {%- endfor -%}
    </div>
  {%- endif -%}
</section>

<style>
  .alsel-lookbook {
    padding: 3rem 1rem;
    background: {{ section.settings.bg_color }};
    color: {{ section.settings.text_color }};
  }
  .alsel-lookbook__header { max-width: 900px; margin: 0 auto 2rem; text-align: center; }
  .alsel-lookbook__heading {
    font-size: clamp(1.6rem, 4.5vw, 2.6rem);
    font-weight: 700;
    letter-spacing: 0.08em;
    margin: 0 0 0.75rem;
  }
  .alsel-lookbook__sub {
    font-size: 0.95rem;
    line-height: 1.7;
    margin: 0;
    opacity: 0.8;
  }
  .alsel-lookbook__empty {
    text-align: center;
    color: #888;
    padding: 2rem 0;
    margin: 0;
  }
  .alsel-lookbook__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
    max-width: 1400px;
    margin: 0 auto;
  }
  .alsel-lookbook__item {
    display: block;
    text-decoration: none;
    color: inherit;
    transition: transform 0.4s ease, opacity 0.3s ease;
  }
  a.alsel-lookbook__item:hover { opacity: 0.9; transform: translateY(-2px); }
  .alsel-lookbook__figure {
    position: relative;
    margin: 0;
    overflow: hidden;
    aspect-ratio: 3 / 4;
    background: #eaeaea;
    border-radius: 4px;
  }
  .alsel-lookbook__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.6s ease;
  }
  a.alsel-lookbook__item:hover .alsel-lookbook__image { transform: scale(1.04); }
  .alsel-lookbook__placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #aaa;
    font-size: 1rem;
    letter-spacing: 0.2em;
  }
  .alsel-lookbook__badge {
    position: absolute;
    top: 0.75rem;
    left: 0.75rem;
    background: {{ section.settings.badge_bg }};
    color: {{ section.settings.badge_color }};
    font-size: 0.75rem;
    font-weight: 700;
    padding: 0.3rem 0.7rem;
    border-radius: 9999px;
    letter-spacing: 0.05em;
  }
  .alsel-lookbook__caption {
    padding: 0.9rem 0.25rem 0;
    text-align: left;
  }
  .alsel-lookbook__title {
    font-size: 1rem;
    font-weight: 700;
    margin: 0 0 0.4rem;
    letter-spacing: 0.04em;
  }
  .alsel-lookbook__text {
    font-size: 0.85rem;
    line-height: 1.6;
    margin: 0 0 0.5rem;
    opacity: 0.75;
  }
  .alsel-lookbook__more {
    display: inline-block;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    border-bottom: 1px solid currentColor;
    padding-bottom: 2px;
  }
  @media (min-width: 750px) {
    .alsel-lookbook { padding: 5rem 2rem; }
    .alsel-lookbook__header { margin-bottom: 3rem; }
    .alsel-lookbook__grid { gap: 2rem; }
    .alsel-lookbook__grid--cols-2 { grid-template-columns: repeat(2, 1fr); }
    .alsel-lookbook__grid--cols-3 { grid-template-columns: repeat(3, 1fr); }
    .alsel-lookbook__grid--cols-4 { grid-template-columns: repeat(4, 1fr); }
    .alsel-lookbook__caption { padding: 1.2rem 0.25rem 0; }
    .alsel-lookbook__title { font-size: 1.1rem; }
    .alsel-lookbook__text { font-size: 0.9rem; }
  }
</style>

{% schema %}
{
  "name": "アパレルLOOKBOOK",
  "tag": "section",
  "class": "alsel-section",
  "settings": [
    { "type": "text", "id": "heading", "label": "セクション見出し", "default": "LOOKBOOK" },
    { "type": "textarea", "id": "subheading", "label": "サブコピー", "default": "今シーズンのおすすめコーディネートをご紹介します。" },
    {
      "type": "select",
      "id": "columns",
      "label": "PC 表示時の列数",
      "options": [
        { "value": "2", "label": "2 カラム" },
        { "value": "3", "label": "3 カラム" },
        { "value": "4", "label": "4 カラム" }
      ],
      "default": "3",
      "info": "モバイルでは常に 1 カラムで表示されます。"
    },
    { "type": "color", "id": "bg_color", "label": "背景色", "default": "#ffffff" },
    { "type": "color", "id": "text_color", "label": "文字色", "default": "#1a1a1a" },
    { "type": "color", "id": "badge_bg", "label": "バッジ背景色", "default": "#1a1a1a" },
    { "type": "color", "id": "badge_color", "label": "バッジ文字色", "default": "#ffffff" }
  ],
  "blocks": [
    {
      "type": "look",
      "name": "ルック",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "モデル画像", "info": "推奨 1200 × 1600px(3:4 縦長)、JPEG または PNG" },
        { "type": "text", "id": "title", "label": "コーデタイトル", "default": "LOOK 01" },
        { "type": "textarea", "id": "caption", "label": "キャプション", "default": "シーズンを彩るおすすめスタイルです。" },
        { "type": "text", "id": "badge", "label": "バッジ文字", "info": "「新作アイテム」「期間限定」など補足ラベル(任意)" },
        { "type": "url", "id": "link", "label": "リンク先", "info": "商品ページまたはコレクションページの URL を設定します。" },
        { "type": "text", "id": "link_text", "label": "リンクのテキスト", "default": "アイテムを見る" }
      ]
    }
  ],
  "presets": [
    {
      "name": "ALSEL監修 / アパレルLOOKBOOK(モデル画像グリッド)",
      "settings": {
        "heading": "LOOKBOOK",
        "subheading": "今シーズンのおすすめコーディネートをご紹介します。",
        "columns": "3"
      },
      "blocks": [
        {
          "type": "look",
          "settings": {
            "title": "LOOK 01",
            "caption": "上品な大人カジュアルを叶える定番スタイルです。",
            "badge": "新作アイテム",
            "link_text": "アイテムを見る"
          }
        },
        {
          "type": "look",
          "settings": {
            "title": "LOOK 02",
            "caption": "シンプルながら華やかさを演出するきれいめコーデです。",
            "badge": "人気スタイル",
            "link_text": "アイテムを見る"
          }
        },
        {
          "type": "look",
          "settings": {
            "title": "LOOK 03",
            "caption": "デイリーに着こなせるリラックススタイルです。",
            "badge": "期間限定",
            "link_text": "アイテムを見る"
          }
        }
      ]
    }
  ]
}
{% endschema %}