{% comment %}
============================================================
セクション名: スマホ専用ヒーロー
用途: PC とスマホで別の画像・別のコピーを出し分けることで、デバイスごとに最適な訴求ができるファーストビューを作る
推奨設置場所: トップページの最上部、または LP の冒頭
カスタマイズポイント:
  - PC 用背景画像(推奨 1600 × 900px)とスマホ用背景画像(推奨 750 × 1000px)を個別に設定できる
  - PC 用見出し・サブコピーと、スマホ用見出し・サブコピーを個別に設定できる
  - CTA ボタン(文字・リンク先・色)
  - 文字色・文字配置・オーバーレイ濃度
注意点:
  - スマホ用画像が未設定の場合は PC 用画像をそのまま表示する
  - 表示切替は CSS のメディアクエリで行う(749px が境界)
  - 画像は Shopify CDN で WebP に自動変換される
動作確認バージョン: Online Store 2.0
ライセンス: ALSEL Original
============================================================
{% endcomment %}

<section class="alsel-hero-mobile" aria-label="{{ section.settings.heading_pc | escape }}">
  <div class="alsel-hero-mobile__media">
    {%- if section.settings.image_pc != blank -%}
      {%- assign alt_1 = section.settings.heading_pc | escape -%}
{{ section.settings.image_pc
        | image_url: width: 1600
        | image_tag: loading: 'eager', class: 'alsel-hero-mobile__img alsel-hero-mobile__img--pc', alt: alt_1, widths: '750, 1100, 1500, 1600' }}
    {%- endif -%}
    {%- if section.settings.image_sp != blank -%}
      {%- assign alt_2 = section.settings.heading_sp | escape -%}
{{ section.settings.image_sp
        | image_url: width: 1000
        | image_tag: loading: 'eager', class: 'alsel-hero-mobile__img alsel-hero-mobile__img--sp', alt: alt_2, widths: '375, 600, 750, 1000' }}
    {%- elsif section.settings.image_pc != blank -%}
      {%- assign alt_3 = section.settings.heading_pc | escape -%}
{{ section.settings.image_pc
        | image_url: width: 1000
        | image_tag: loading: 'eager', class: 'alsel-hero-mobile__img alsel-hero-mobile__img--sp', alt: alt_3, widths: '375, 600, 750, 1000' }}
    {%- endif -%}
    <div class="alsel-hero-mobile__overlay" aria-hidden="true"></div>
  </div>

  <div class="alsel-hero-mobile__inner">
    <div class="alsel-hero-mobile__content alsel-hero-mobile__content--pc">
      {%- if section.settings.heading_pc != blank -%}
        <h2 class="alsel-hero-mobile__title">{{ section.settings.heading_pc }}</h2>
      {%- endif -%}
      {%- if section.settings.subheading_pc != blank -%}
        <p class="alsel-hero-mobile__sub">{{ section.settings.subheading_pc }}</p>
      {%- endif -%}
    </div>
    <div class="alsel-hero-mobile__content alsel-hero-mobile__content--sp">
      {%- if section.settings.heading_sp != blank -%}
        <h2 class="alsel-hero-mobile__title">{{ section.settings.heading_sp }}</h2>
      {%- elsif section.settings.heading_pc != blank -%}
        <h2 class="alsel-hero-mobile__title">{{ section.settings.heading_pc }}</h2>
      {%- endif -%}
      {%- if section.settings.subheading_sp != blank -%}
        <p class="alsel-hero-mobile__sub">{{ section.settings.subheading_sp }}</p>
      {%- elsif section.settings.subheading_pc != blank -%}
        <p class="alsel-hero-mobile__sub">{{ section.settings.subheading_pc }}</p>
      {%- endif -%}
    </div>

    {%- if section.settings.cta_text != blank and section.settings.cta_link != blank -%}
      <a class="alsel-hero-mobile__cta" href="{{ section.settings.cta_link }}" aria-label="{{ section.settings.cta_text | escape }}">
        {{ section.settings.cta_text }}
      </a>
    {%- endif -%}
  </div>
</section>

<style>
  .alsel-hero-mobile {
    --text-color: {{ section.settings.text_color }};
    --cta-bg: {{ section.settings.cta_bg }};
    --cta-color: {{ section.settings.cta_color }};
    --overlay: {{ section.settings.overlay_opacity | times: 0.01 }};
    position: relative;
    overflow: hidden;
    min-height: 70vh;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .alsel-hero-mobile__media { position: absolute; inset: 0; z-index: 0; }
  .alsel-hero-mobile__img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
  .alsel-hero-mobile__img--pc { display: none; }
  .alsel-hero-mobile__img--sp { display: block; }
  .alsel-hero-mobile__overlay {
    position: absolute; inset: 0;
    background: #000;
    opacity: var(--overlay);
  }
  .alsel-hero-mobile__inner {
    position: relative;
    z-index: 1;
    padding: 3rem 1.5rem;
    max-width: 900px;
    width: 100%;
    color: var(--text-color);
    text-align: {{ section.settings.text_align }};
  }
  .alsel-hero-mobile__content--pc { display: none; }
  .alsel-hero-mobile__content--sp { display: block; }
  .alsel-hero-mobile__title {
    font-size: clamp(1.6rem, 6vw, 2.4rem);
    font-weight: 700;
    line-height: 1.35;
    margin: 0 0 1rem;
  }
  .alsel-hero-mobile__sub {
    font-size: 1rem;
    line-height: 1.7;
    margin: 0 0 1.75rem;
  }
  .alsel-hero-mobile__cta {
    display: inline-block;
    padding: 0.95rem 2.2rem;
    background: var(--cta-bg);
    color: var(--cta-color);
    text-decoration: none;
    border-radius: 9999px;
    font-weight: 700;
    font-size: 1rem;
    transition: transform 0.2s ease, opacity 0.2s ease;
  }
  .alsel-hero-mobile__cta:hover { transform: translateY(-2px); opacity: 0.92; }

  @media (min-width: 750px) {
    .alsel-hero-mobile { min-height: 80vh; }
    .alsel-hero-mobile__img--pc { display: block; }
    .alsel-hero-mobile__img--sp { display: none; }
    .alsel-hero-mobile__content--pc { display: block; }
    .alsel-hero-mobile__content--sp { display: none; }
    .alsel-hero-mobile__inner { padding: 5rem 2rem; }
    .alsel-hero-mobile__title { font-size: clamp(2rem, 4vw, 3.2rem); }
    .alsel-hero-mobile__sub { font-size: 1.1rem; }
  }
</style>

{% schema %}
{
  "name": "スマホ専用ヒーロー",
  "tag": "section",
  "class": "alsel-section",
  "settings": [
    { "type": "header", "content": "PC 用設定" },
    { "type": "image_picker", "id": "image_pc", "label": "PC 用背景画像", "info": "推奨 1600 × 900px、JPEG または PNG" },
    { "type": "text", "id": "heading_pc", "label": "PC 用見出し", "default": "PC 表示時のメインメッセージ" },
    { "type": "textarea", "id": "subheading_pc", "label": "PC 用サブコピー", "default": "PC 表示時の説明文をここに入力します。" },

    { "type": "header", "content": "スマホ用設定" },
    { "type": "image_picker", "id": "image_sp", "label": "スマホ用背景画像", "info": "推奨 750 × 1000px(縦長)、未設定なら PC 画像を使用" },
    { "type": "text", "id": "heading_sp", "label": "スマホ用見出し", "default": "スマホ用の短い訴求" },
    { "type": "textarea", "id": "subheading_sp", "label": "スマホ用サブコピー", "info": "未入力なら PC 用を表示", "default": "短く、読みやすく。" },

    { "type": "header", "content": "CTA ボタン" },
    { "type": "text", "id": "cta_text", "label": "ボタンの文字", "default": "詳しく見る" },
    { "type": "url", "id": "cta_link", "label": "ボタンのリンク先" },
    { "type": "color", "id": "cta_bg", "label": "ボタン背景色", "default": "#111827" },
    { "type": "color", "id": "cta_color", "label": "ボタン文字色", "default": "#ffffff" },

    { "type": "header", "content": "見た目の調整" },
    { "type": "color", "id": "text_color", "label": "文字色", "default": "#ffffff" },
    { "type": "select", "id": "text_align", "label": "文字の配置",
      "options": [
        { "value": "left", "label": "左寄せ" },
        { "value": "center", "label": "中央" },
        { "value": "right", "label": "右寄せ" }
      ],
      "default": "center" },
    { "type": "range", "id": "overlay_opacity", "label": "オーバーレイ濃度(%)", "min": 0, "max": 80, "step": 5, "default": 30, "info": "背景画像の上に黒のオーバーレイをかけて文字を読みやすくする" }
  ],
  "presets": [
    {
      "name": "ALSEL監修 / スマホ専用ヒーロー",
      "settings": {
        "heading_pc": "PC とスマホで最適な見せ方を",
        "subheading_pc": "デバイスごとに画像とコピーを出し分けて、伝わるファーストビューを作る。",
        "heading_sp": "スマホ最適化",
        "subheading_sp": "短く、読みやすく届ける。",
        "cta_text": "詳しく見る"
      }
    }
  ]
}
{% endschema %}