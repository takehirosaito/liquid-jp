{% comment %}
============================================================
セクション名: ポップアップ風セクション
用途: 実際のポップアップではなく、ページ内に埋め込む「目立つ告知枠」をつくります。期間限定キャンペーンや重要なお知らせを、ポップアップ風のデザインで注意を引きつけて訴求するのに向いています。
推奨設置場所: トップページの上部、商品ページのカート上部、LP の途中など
カスタマイズポイント:
  - 告知ラベル(NEW / 期間限定 など)
  - 見出し・本文
  - ボタン(文字・リンク先)
  - 装飾アイコン画像(任意)
  - 背景色・アクセントカラー・文字色
  - 角丸の大きさ・影の有無
注意点:
  - 実際のモーダルではないため、閉じる動作はない(常時表示)
  - アイコン画像は推奨 120 × 120px、PNG 透過
  - Online Store 2.0 必須
動作確認バージョン: Online Store 2.0
ライセンス: ALSEL Original
============================================================
{% endcomment %}

{%- assign icon_alt = section.settings.heading | default: 'お知らせ' | escape -%}

<section class="alsel-popup-notice" aria-label="{{ section.settings.heading | escape }}">
  <div class="alsel-popup-notice__wrap">
    <div class="alsel-popup-notice__card{%- if section.settings.show_shadow %} alsel-popup-notice__card--shadow{%- endif -%}">
      {%- if section.settings.icon_image != blank -%}
        <div class="alsel-popup-notice__icon-wrap">
          {{ section.settings.icon_image | image_url: width: 240 | image_tag: loading: 'lazy', class: 'alsel-popup-notice__icon', alt: icon_alt, widths: '120, 240' }}
        </div>
      {%- endif -%}

      {%- if section.settings.label != blank -%}
        <span class="alsel-popup-notice__label">{{ section.settings.label }}</span>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h2 class="alsel-popup-notice__title">{{ section.settings.heading }}</h2>
      {%- endif -%}

      {%- if section.settings.body != blank -%}
        <div class="alsel-popup-notice__body">{{ section.settings.body }}</div>
      {%- endif -%}

      {%- if section.settings.cta_text != blank and section.settings.cta_link != blank -%}
        <a class="alsel-popup-notice__cta" href="{{ section.settings.cta_link }}" aria-label="{{ section.settings.cta_text | escape }}">
          {{ section.settings.cta_text }}
          <span class="alsel-popup-notice__cta-arrow" aria-hidden="true">→</span>
        </a>
      {%- endif -%}

      {%- if section.settings.note != blank -%}
        <p class="alsel-popup-notice__note">{{ section.settings.note }}</p>
      {%- endif -%}
    </div>
  </div>
</section>

<style>
  .alsel-popup-notice {
    padding: 2rem 1rem;
    background: {{ section.settings.section_bg }};
  }
  .alsel-popup-notice__wrap {
    max-width: 720px;
    margin: 0 auto;
  }
  .alsel-popup-notice__card {
    position: relative;
    background: {{ section.settings.card_bg }};
    color: {{ section.settings.text_color }};
    border: 2px solid {{ section.settings.accent_color }};
    border-radius: {{ section.settings.radius }}px;
    padding: 2.5rem 1.5rem 2rem;
    text-align: center;
  }
  .alsel-popup-notice__card--shadow {
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.15);
  }
  .alsel-popup-notice__icon-wrap {
    margin: 0 auto 1rem;
    width: 80px;
    height: 80px;
  }
  .alsel-popup-notice__icon {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }
  .alsel-popup-notice__label {
    display: inline-block;
    background: {{ section.settings.accent_color }};
    color: {{ section.settings.label_text_color }};
    padding: 0.35rem 1rem;
    border-radius: 9999px;
    font-size: 0.8rem;
    font-weight: 700;
    margin-bottom: 1rem;
    letter-spacing: 0.05em;
  }
  .alsel-popup-notice__title {
    font-size: clamp(1.3rem, 4.5vw, 1.8rem);
    font-weight: 700;
    line-height: 1.4;
    margin: 0 0 1rem;
    color: {{ section.settings.accent_color }};
  }
  .alsel-popup-notice__body {
    font-size: 0.95rem;
    line-height: 1.8;
    margin: 0 0 1.5rem;
  }
  .alsel-popup-notice__body p {
    margin: 0 0 0.5rem;
  }
  .alsel-popup-notice__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.9rem 2rem;
    background: {{ section.settings.accent_color }};
    color: {{ section.settings.cta_text_color }};
    text-decoration: none;
    border-radius: 9999px;
    font-weight: 700;
    font-size: 0.95rem;
    transition: transform 0.2s ease, opacity 0.2s ease;
  }
  .alsel-popup-notice__cta:hover {
    transform: translateY(-2px);
    opacity: 0.92;
  }
  .alsel-popup-notice__cta-arrow {
    transition: transform 0.2s ease;
  }
  .alsel-popup-notice__cta:hover .alsel-popup-notice__cta-arrow {
    transform: translateX(4px);
  }
  .alsel-popup-notice__note {
    margin: 1.25rem 0 0;
    font-size: 0.8rem;
    color: #6b7280;
    line-height: 1.6;
  }
  @media (min-width: 750px) {
    .alsel-popup-notice {
      padding: 4rem 2rem;
    }
    .alsel-popup-notice__card {
      padding: 3rem 2.5rem 2.5rem;
    }
    .alsel-popup-notice__icon-wrap {
      width: 100px;
      height: 100px;
    }
  }
</style>

{% schema %}
{
  "name": "ポップアップ風お知らせ枠",
  "tag": "section",
  "class": "alsel-section",
  "settings": [
    { "type": "header", "content": "コンテンツ" },
    { "type": "image_picker", "id": "icon_image", "label": "装飾アイコン画像", "info": "推奨 120 × 120px、PNG 透過。空欄でも表示されます。" },
    { "type": "text", "id": "label", "label": "ラベル", "default": "期間限定のお知らせ", "info": "見出しの上に表示される小さなバッジです。" },
    { "type": "text", "id": "heading", "label": "見出し", "default": "重要なお知らせがあります" },
    { "type": "richtext", "id": "body", "label": "本文", "default": "<p>キャンペーンや重要な告知をこちらにご記入ください。文字を強調したり、改行で読みやすく整えたりできます。</p>" },
    { "type": "text", "id": "cta_text", "label": "ボタンの文字", "default": "詳しくはこちら" },
    { "type": "url", "id": "cta_link", "label": "ボタンのリンク先" },
    { "type": "text", "id": "note", "label": "補足テキスト", "default": "※ 内容は予告なく変更となる場合がございます。", "info": "ボタンの下に小さく表示される注釈です。" },

    { "type": "header", "content": "デザイン" },
    { "type": "color", "id": "section_bg", "label": "セクション背景色", "default": "#f3f4f6" },
    { "type": "color", "id": "card_bg", "label": "カード背景色", "default": "#ffffff" },
    { "type": "color", "id": "accent_color", "label": "アクセントカラー", "default": "#dc2626", "info": "見出し・ボタン・枠線・ラベル背景に使用されます。" },
    { "type": "color", "id": "text_color", "label": "本文の文字色", "default": "#1f2937" },
    { "type": "color", "id": "label_text_color", "label": "ラベルの文字色", "default": "#ffffff" },
    { "type": "color", "id": "cta_text_color", "label": "ボタンの文字色", "default": "#ffffff" },
    { "type": "range", "id": "radius", "label": "角丸の大きさ", "min": 0, "max": 32, "step": 2, "unit": "px", "default": 16 },
    { "type": "checkbox", "id": "show_shadow", "label": "影をつける", "default": true }
  ],
  "presets": [
    {
      "name": "ALSEL監修 / ポップアップ風お知らせ枠(中央カード)",
      "settings": {
        "label": "期間限定のお知らせ",
        "heading": "重要なお知らせがあります",
        "body": "<p>キャンペーンや重要な告知をこちらにご記入ください。文字を強調したり、改行で読みやすく整えたりできます。</p>",
        "cta_text": "詳しくはこちら",
        "note": "※ 内容は予告なく変更となる場合がございます。",
        "section_bg": "#f3f4f6",
        "card_bg": "#ffffff",
        "accent_color": "#dc2626",
        "text_color": "#1f2937",
        "label_text_color": "#ffffff",
        "cta_text_color": "#ffffff",
        "radius": 16,
        "show_shadow": true
      }
    }
  ]
}
{% endschema %}