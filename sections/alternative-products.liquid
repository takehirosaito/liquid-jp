{% comment %}
============================================================
セクション名: 売り切れ時の代替商品
用途: 商品ページで対象商品が在庫切れの際に、代わりにおすすめできる商品を一覧で提示するためのセクション。離脱を防ぎ、別商品への回遊を促す。
推奨設置場所: 商品ページ(main-product.json の下部)
カスタマイズポイント:
  - セクション見出し・補足文
  - 強制表示モード(在庫の有無にかかわらず常に表示)
  - 売り切れバッジの文言・色
  - おすすめ商品カード(画像・タイトル・価格・リンク)を最大 8 件まで
  - 背景色・カラム数(モバイル / PC)
注意点:
  - 商品ページ以外に設置した場合は product コンテキストが取れないため、強制表示モードを ON にして利用
  - 商品画像は正方形(推奨 800 × 800px)が美しく並ぶ
  - ブロックは最低 3 件、最大 8 件を推奨
動作確認バージョン: Online Store 2.0
ライセンス: ALSEL Original
============================================================
{% endcomment %}

{%- assign show_section = false -%}
{%- if section.settings.force_show -%}
  {%- assign show_section = true -%}
{%- elsif product != blank and product.available == false -%}
  {%- assign show_section = true -%}
{%- endif -%}

{%- if show_section -%}
<section class="alsel-alternative-products" aria-label="{{ section.settings.heading | escape }}">
  <div class="alsel-alternative-products__inner">
    {%- if product != blank and product.available == false -%}
      <span class="alsel-alternative-products__badge">{{ section.settings.sold_out_label }}</span>
    {%- endif -%}
    {%- if section.settings.heading != blank -%}
      <h2 class="alsel-alternative-products__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}
    {%- if section.settings.subheading != blank -%}
      <p class="alsel-alternative-products__sub">{{ section.settings.subheading }}</p>
    {%- endif -%}

    {%- if section.blocks.size == 0 -%}
      <p class="alsel-alternative-products__empty">
        表示する代替商品はまだ登録されていません。テーマエディタからブロックを追加してください。
      </p>
    {%- else -%}
      <div class="alsel-alternative-products__grid">
        {%- for block in section.blocks -%}
          {%- assign card_title = block.settings.title | escape -%}
          <a class="alsel-alternative-products__card"
             href="{{ block.settings.link | default: '#' }}"
             aria-label="{{ card_title }}の詳細を見る"
             {{ block.shopify_attributes }}>
            <div class="alsel-alternative-products__media">
              {%- if block.settings.image != blank -%}
                {{ block.settings.image | image_url: width: 800 | image_tag: loading: 'lazy', class: 'alsel-alternative-products__img', alt: card_title, widths: '300, 500, 800', sizes: '(min-width: 750px) 25vw, 50vw' }}
              {%- else -%}
                <div class="alsel-alternative-products__noimg" aria-hidden="true">No Image</div>
              {%- endif -%}
              {%- if block.settings.tag_label != blank -%}
                <span class="alsel-alternative-products__tag">{{ block.settings.tag_label }}</span>
              {%- endif -%}
            </div>
            <div class="alsel-alternative-products__body">
              <h3 class="alsel-alternative-products__title">{{ block.settings.title }}</h3>
              {%- if block.settings.price != blank -%}
                <p class="alsel-alternative-products__price">{{ block.settings.price }}</p>
              {%- endif -%}
              {%- if block.settings.cta_text != blank -%}
                <span class="alsel-alternative-products__cta">{{ block.settings.cta_text }}</span>
              {%- endif -%}
            </div>
          </a>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>
{%- endif -%}

<style>
  .alsel-alternative-products { padding: 3rem 1rem; background: {{ section.settings.bg_color }}; }
  .alsel-alternative-products__inner { max-width: 1200px; margin: 0 auto; }
  .alsel-alternative-products__badge { display: inline-block; padding: 0.35rem 0.9rem; background: {{ section.settings.badge_bg }}; color: {{ section.settings.badge_color }}; border-radius: 9999px; font-size: 0.8rem; font-weight: 700; margin: 0 0 0.75rem; }
  .alsel-alternative-products__heading { font-size: clamp(1.4rem, 4vw, 2.2rem); font-weight: 700; margin: 0 0 0.75rem; color: {{ section.settings.text_color }}; }
  .alsel-alternative-products__sub { font-size: 0.95rem; line-height: 1.7; color: {{ section.settings.text_color }}; opacity: 0.85; margin: 0 0 2rem; }
  .alsel-alternative-products__empty { text-align: center; color: #888; padding: 2rem 0; }
  .alsel-alternative-products__grid { display: grid; gap: 1rem; grid-template-columns: repeat({{ section.settings.columns_mobile }}, 1fr); }
  .alsel-alternative-products__card { display: flex; flex-direction: column; background: #fff; border-radius: 12px; overflow: hidden; text-decoration: none; color: inherit; box-shadow: 0 2px 8px rgba(0,0,0,0.06); transition: transform 0.2s ease, box-shadow 0.2s ease; }
  .alsel-alternative-products__card:hover { transform: translateY(-3px); box-shadow: 0 6px 18px rgba(0,0,0,0.1); }
  .alsel-alternative-products__media { position: relative; aspect-ratio: 1 / 1; background: #f1f5f9; overflow: hidden; }
  .alsel-alternative-products__img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .alsel-alternative-products__noimg { width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; color: #94a3b8; font-size: 0.85rem; }
  .alsel-alternative-products__tag { position: absolute; top: 0.6rem; left: 0.6rem; padding: 0.25rem 0.6rem; background: rgba(0,0,0,0.7); color: #fff; border-radius: 4px; font-size: 0.7rem; font-weight: 700; }
  .alsel-alternative-products__body { padding: 0.9rem; display: flex; flex-direction: column; gap: 0.4rem; }
  .alsel-alternative-products__title { font-size: 0.95rem; font-weight: 700; line-height: 1.4; margin: 0; color: #0f172a; }
  .alsel-alternative-products__price { font-size: 1rem; font-weight: 700; color: {{ section.settings.price_color }}; margin: 0; }
  .alsel-alternative-products__cta { display: inline-block; margin-top: 0.4rem; padding: 0.5rem 0.8rem; background: {{ section.settings.cta_bg }}; color: {{ section.settings.cta_color }}; border-radius: 6px; font-size: 0.85rem; font-weight: 700; text-align: center; }
  @media (min-width: 750px) {
    .alsel-alternative-products { padding: 5rem 2rem; }
    .alsel-alternative-products__grid { gap: 1.5rem; grid-template-columns: repeat({{ section.settings.columns_desktop }}, 1fr); }
    .alsel-alternative-products__body { padding: 1.1rem; }
    .alsel-alternative-products__title { font-size: 1rem; }
  }
</style>

{% schema %}
{
  "name": "売り切れ時の代替商品",
  "tag": "section",
  "class": "alsel-section",
  "settings": [
    { "type": "header", "content": "表示条件" },
    { "type": "checkbox", "id": "force_show", "label": "常に表示する", "default": false, "info": "ON にすると在庫の有無にかかわらず常に表示します。商品ページ以外に置く場合は ON にしてください。" },
    { "type": "header", "content": "見出し" },
    { "type": "text", "id": "sold_out_label", "label": "売り切れバッジの文字", "default": "申し訳ございません、売り切れです" },
    { "type": "text", "id": "heading", "label": "セクション見出し", "default": "こちらの商品はいかがでしょうか" },
    { "type": "textarea", "id": "subheading", "label": "補足文", "default": "ご検討中の商品によく似たおすすめ商品をご紹介します。ぜひ合わせてご覧ください。" },
    { "type": "header", "content": "レイアウト" },
    { "type": "select", "id": "columns_mobile", "label": "カラム数(モバイル)",
      "options": [
        { "value": "1", "label": "1 カラム" },
        { "value": "2", "label": "2 カラム" }
      ],
      "default": "2" },
    { "type": "select", "id": "columns_desktop", "label": "カラム数(PC)",
      "options": [
        { "value": "2", "label": "2 カラム" },
        { "value": "3", "label": "3 カラム" },
        { "value": "4", "label": "4 カラム" }
      ],
      "default": "4" },
    { "type": "header", "content": "配色" },
    { "type": "color", "id": "bg_color", "label": "背景色", "default": "#fef2f2" },
    { "type": "color", "id": "text_color", "label": "文字色", "default": "#0f172a" },
    { "type": "color", "id": "badge_bg", "label": "バッジ背景色", "default": "#dc2626" },
    { "type": "color", "id": "badge_color", "label": "バッジ文字色", "default": "#ffffff" },
    { "type": "color", "id": "price_color", "label": "価格の文字色", "default": "#dc2626" },
    { "type": "color", "id": "cta_bg", "label": "ボタン背景色", "default": "#0f172a" },
    { "type": "color", "id": "cta_color", "label": "ボタン文字色", "default": "#ffffff" }
  ],
  "blocks": [
    {
      "type": "product_card",
      "name": "代替商品カード",
      "limit": 8,
      "settings": [
        { "type": "image_picker", "id": "image", "label": "商品画像", "info": "推奨 800 × 800px の正方形、JPEG または PNG" },
        { "type": "text", "id": "title", "label": "商品名", "default": "おすすめ商品名" },
        { "type": "text", "id": "price", "label": "価格表示", "default": "¥3,980(税込)" },
        { "type": "text", "id": "tag_label", "label": "左上タグ(任意)", "info": "「人気商品」「新着商品」など。空欄で非表示。" },
        { "type": "text", "id": "cta_text", "label": "ボタンの文字", "default": "詳しく見る" },
        { "type": "url", "id": "link", "label": "リンク先" }
      ]
    }
  ],
  "presets": [
    {
      "name": "ALSEL監修 / 売り切れ時の代替商品(カードグリッド)",
      "settings": {
        "force_show": false,
        "sold_out_label": "申し訳ございません、売り切れです",
        "heading": "こちらの商品はいかがでしょうか",
        "subheading": "ご検討中の商品によく似たおすすめ商品をご紹介します。ぜひ合わせてご覧ください。",
        "columns_mobile": "2",
        "columns_desktop": "4"
      },
      "blocks": [
        { "type": "product_card", "settings": { "title": "人気のおすすめ商品 A", "price": "¥3,980(税込)", "tag_label": "人気商品", "cta_text": "詳しく見る" } },
        { "type": "product_card", "settings": { "title": "新着のおすすめ商品 B", "price": "¥4,500(税込)", "tag_label": "新着商品", "cta_text": "詳しく見る" } },
        { "type": "product_card", "settings": { "title": "定番のおすすめ商品 C", "price": "¥3,200(税込)", "tag_label": "ロングセラー", "cta_text": "詳しく見る" } },
        { "type": "product_card", "settings": { "title": "期間限定のおすすめ商品 D", "price": "¥5,800(税込)", "tag_label": "期間限定", "cta_text": "詳しく見る" } }
      ]
    }
  ]
}
{% endschema %}