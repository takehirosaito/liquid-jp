{% comment %}
============================================================
セクション名: 楽天風ランキング表示
用途: 売れ筋商品やおすすめ商品の上位3件を、楽天風の表彰台レイアウトで大きく見せる。トップページや特集ページで「人気No.1」を強調したい場面に最適。
推奨設置場所: トップページの中段、コレクションページの上部、特集 LP の途中
カスタマイズポイント:
  - 表示するコレクション(上位3件を自動取得)
  - セクション見出し・サブコピー
  - 1位・2位・3位のメダル絵文字(王冠 / 銀 / 銅)
  - 各順位の背景色・アクセントカラー
  - 背景色・ボタン文字
注意点:
  - 表示するコレクションを1つ選ぶこと(未選択だとセクションは表示されない)
  - コレクション内の商品が3件未満の場合、足りない順位は自動的に非表示になる
  - 商品画像は Shopify の正方形サムネイル(推奨 1000 × 1000px)を想定
  - HTML 上は 1位 → 2位 → 3位 の順で出力し、CSS Grid の order で「2位・1位・3位」に並び替える
動作確認バージョン: Online Store 2.0
ライセンス: ALSEL Original
============================================================
{% endcomment %}

{%- assign ranking_collection = collections[section.settings.ranking_collection] -%}
{%- assign ranking_products = ranking_collection.products | slice: 0, 3 -%}

<section class="alsel-ranking-top-three" aria-label="{{ section.settings.heading | escape }}">
  <div class="alsel-ranking-top-three__inner">
    {%- if section.settings.heading != blank -%}
      <h2 class="alsel-ranking-top-three__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}
    {%- if section.settings.subheading != blank -%}
      <p class="alsel-ranking-top-three__sub">{{ section.settings.subheading }}</p>
    {%- endif -%}

    {%- if ranking_products.size > 0 -%}
      <div class="alsel-ranking-top-three__grid">
        {%- for product in ranking_products -%}
          {%- if forloop.index > 3 -%}{%- break -%}{%- endif -%}
          {%- assign rank = forloop.index -%}
          {%- assign alt_text = product.title | escape -%}
          {%- assign product_image = product.featured_image -%}

          {%- case rank -%}
            {%- when 1 -%}
              {%- assign rank_class = 'is-first' -%}
              {%- assign rank_label = '1位' -%}
              {%- assign medal = section.settings.medal_first -%}
            {%- when 2 -%}
              {%- assign rank_class = 'is-second' -%}
              {%- assign rank_label = '2位' -%}
              {%- assign medal = section.settings.medal_second -%}
            {%- when 3 -%}
              {%- assign rank_class = 'is-third' -%}
              {%- assign rank_label = '3位' -%}
              {%- assign medal = section.settings.medal_third -%}
          {%- endcase -%}

          <article class="alsel-ranking-top-three__card {{ rank_class }}" aria-label="{{ rank_label }} {{ alt_text }}">
            <span class="alsel-ranking-top-three__medal" aria-hidden="true">{{ medal }}</span>
            <span class="alsel-ranking-top-three__rank-label">{{ rank_label }}</span>
            <a class="alsel-ranking-top-three__image-wrap" href="{{ product.url }}" aria-label="{{ alt_text }}">
              {%- if product_image != blank -%}
                {{ product_image | image_url: width: 800 | image_tag: loading: 'lazy', class: 'alsel-ranking-top-three__image', alt: alt_text, widths: '300, 500, 800', sizes: '(min-width: 750px) 33vw, 90vw' }}
              {%- else -%}
                <span class="alsel-ranking-top-three__no-image" aria-hidden="true">No Image</span>
              {%- endif -%}
            </a>
            <h3 class="alsel-ranking-top-three__title">
              <a href="{{ product.url }}">{{ product.title }}</a>
            </h3>
            <p class="alsel-ranking-top-three__price">{{ product.price | money }}</p>
            {%- if section.settings.button_text != blank -%}
              <a class="alsel-ranking-top-three__cta" href="{{ product.url }}" aria-label="{{ alt_text }} の詳細を見る">
                {{ section.settings.button_text }}
              </a>
            {%- endif -%}
          </article>
        {%- endfor -%}
      </div>
    {%- else -%}
      <p class="alsel-ranking-top-three__empty">表示するコレクションを選んでください。</p>
    {%- endif -%}
  </div>
</section>

<style>
  .alsel-ranking-top-three {
    background: {{ section.settings.bg_color }};
    padding: 3rem 1rem;
  }
  .alsel-ranking-top-three__inner {
    max-width: 1100px;
    margin: 0 auto;
  }
  .alsel-ranking-top-three__heading {
    font-size: clamp(1.5rem, 4vw, 2.2rem);
    font-weight: 700;
    text-align: center;
    margin: 0 0 0.5rem;
    color: {{ section.settings.heading_color }};
  }
  .alsel-ranking-top-three__sub {
    text-align: center;
    font-size: 0.95rem;
    line-height: 1.6;
    color: {{ section.settings.heading_color }};
    margin: 0 0 2.5rem;
  }
  .alsel-ranking-top-three__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem 1rem;
    align-items: end;
  }
  .alsel-ranking-top-three__card {
    position: relative;
    background: #fff;
    border-radius: 14px;
    padding: 2rem 1rem 1.25rem;
    text-align: center;
    box-shadow: 0 4px 14px rgba(0,0,0,0.08);
    border-top: 4px solid transparent;
  }
  .alsel-ranking-top-three__card.is-first {
    border-top-color: {{ section.settings.color_first }};
    background: {{ section.settings.bg_first }};
  }
  .alsel-ranking-top-three__card.is-second {
    border-top-color: {{ section.settings.color_second }};
    background: {{ section.settings.bg_second }};
  }
  .alsel-ranking-top-three__card.is-third {
    border-top-color: {{ section.settings.color_third }};
    background: {{ section.settings.bg_third }};
  }
  .alsel-ranking-top-three__medal {
    position: absolute;
    top: -18px;
    left: 50%;
    transform: translateX(-50%);
    font-size: 2.2rem;
    line-height: 1;
    background: #fff;
    border-radius: 9999px;
    width: 56px;
    height: 56px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 2px 6px rgba(0,0,0,0.15);
  }
  .alsel-ranking-top-three__rank-label {
    display: inline-block;
    font-size: 0.85rem;
    font-weight: 700;
    color: #475569;
    margin-top: 1.25rem;
  }
  .alsel-ranking-top-three__image-wrap {
    display: block;
    margin: 0.75rem auto 1rem;
    border-radius: 10px;
    overflow: hidden;
    background: #f1f5f9;
    aspect-ratio: 1 / 1;
  }
  .alsel-ranking-top-three__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .alsel-ranking-top-three__no-image {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
    color: #94a3b8;
    font-size: 0.85rem;
  }
  .alsel-ranking-top-three__title {
    font-size: 0.95rem;
    line-height: 1.5;
    font-weight: 700;
    margin: 0 0 0.5rem;
    min-height: 2.85em;
  }
  .alsel-ranking-top-three__title a {
    color: inherit;
    text-decoration: none;
  }
  .alsel-ranking-top-three__price {
    font-size: 1.05rem;
    font-weight: 700;
    color: #db2c2c;
    margin: 0 0 1rem;
  }
  .alsel-ranking-top-three__cta {
    display: inline-block;
    padding: 0.65rem 1.5rem;
    background: {{ section.settings.button_bg }};
    color: {{ section.settings.button_color }};
    text-decoration: none;
    border-radius: 9999px;
    font-size: 0.9rem;
    font-weight: 700;
  }
  .alsel-ranking-top-three__empty {
    text-align: center;
    color: #64748b;
    padding: 2rem 0;
  }
  .alsel-ranking-top-three__card.is-first {
    order: 2;
    transform: scale(1.04);
  }
  .alsel-ranking-top-three__card.is-second {
    order: 1;
  }
  .alsel-ranking-top-three__card.is-third {
    order: 3;
  }
  @media (min-width: 750px) {
    .alsel-ranking-top-three {
      padding: 5rem 2rem;
    }
    .alsel-ranking-top-three__grid {
      grid-template-columns: 1fr 1.25fr 1fr;
      gap: 1.5rem;
    }
    .alsel-ranking-top-three__card.is-first {
      padding-top: 2.5rem;
    }
    .alsel-ranking-top-three__medal {
      width: 64px;
      height: 64px;
      font-size: 2.6rem;
      top: -22px;
    }
  }
</style>

{% schema %}
{
  "name": "楽天風ランキング表示",
  "tag": "section",
  "class": "alsel-section",
  "settings": [
    { "type": "header", "content": "表示内容" },
    { "type": "collection", "id": "ranking_collection", "label": "ランキング表示するコレクション", "info": "選んだコレクションの上位3件を自動で表示する" },
    { "type": "text", "id": "heading", "label": "セクション見出し", "default": "人気ランキング BEST 3" },
    { "type": "textarea", "id": "subheading", "label": "サブコピー", "default": "売れ筋トップ3を公開中。" },
    { "type": "text", "id": "button_text", "label": "ボタンの文字", "default": "商品を見る" },

    { "type": "header", "content": "メダル(絵文字で変更可能)" },
    { "type": "text", "id": "medal_first", "label": "1位のメダル", "default": "👑" },
    { "type": "text", "id": "medal_second", "label": "2位のメダル", "default": "🥈" },
    { "type": "text", "id": "medal_third", "label": "3位のメダル", "default": "🥉" },

    { "type": "header", "content": "色の設定" },
    { "type": "color", "id": "bg_color", "label": "背景色", "default": "#fff7ed" },
    { "type": "color", "id": "heading_color", "label": "見出し・サブの文字色", "default": "#1e293b" },
    { "type": "color", "id": "color_first", "label": "1位アクセントカラー", "default": "#f59e0b" },
    { "type": "color", "id": "bg_first", "label": "1位カード背景", "default": "#fffbeb" },
    { "type": "color", "id": "color_second", "label": "2位アクセントカラー", "default": "#94a3b8" },
    { "type": "color", "id": "bg_second", "label": "2位カード背景", "default": "#f8fafc" },
    { "type": "color", "id": "color_third", "label": "3位アクセントカラー", "default": "#b45309" },
    { "type": "color", "id": "bg_third", "label": "3位カード背景", "default": "#fef3c7" },
    { "type": "color", "id": "button_bg", "label": "ボタン背景色", "default": "#db2c2c" },
    { "type": "color", "id": "button_color", "label": "ボタン文字色", "default": "#ffffff" }
  ],
  "presets": [
    {
      "name": "ALSEL監修 / 楽天風ランキング表示",
      "settings": {
        "heading": "人気ランキング BEST 3",
        "subheading": "売れ筋トップ3を公開中。",
        "button_text": "商品を見る",
        "medal_first": "👑",
        "medal_second": "🥈",
        "medal_third": "🥉"
      }
    }
  ]
}
{% endschema %}