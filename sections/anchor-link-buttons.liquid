{% comment %}
============================================================
セクション名: アンカーリンクボタン群
用途: 商品ページや LP の冒頭に設置し、「特徴」「レビュー」「送料」「FAQ」など、同ページ内の各セクションへワンタップで移動できるナビゲーションを提供する
推奨設置場所: 商品ページ・ランディングページ・トップページのヒーロー直下
カスタマイズポイント:
  - 各ボタンのラベル・アンカー先 ID(# 付き)
  - ボタンのデザイン(背景色・文字色・枠線色・角丸)
  - レイアウト(横並び / 横スクロール / グリッド)
  - 区切り線の表示有無
  - スティッキー固定の有無
注意点:
  - リンク先 ID は他セクションの id 属性と一致させる(例: #features / #reviews)
  - ボタンは 2〜8 個推奨
  - 横スクロール表示時はモバイルで横にスワイプ可能
動作確認バージョン: Online Store 2.0
ライセンス: ALSEL Original
============================================================
{% endcomment %}

{%- assign aria_label = section.settings.heading | default: 'ページ内ナビゲーション' | escape -%}

<section class="alsel-anchor-link-buttons alsel-anchor-link-buttons--{{ section.settings.layout }}{%- if section.settings.is_sticky %} alsel-anchor-link-buttons--sticky{%- endif -%}" aria-label="{{ aria_label }}">
  <div class="alsel-anchor-link-buttons__inner">
    {%- if section.settings.heading != blank -%}
      <h2 class="alsel-anchor-link-buttons__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    {%- if section.blocks.size == 0 -%}
      <p class="alsel-anchor-link-buttons__empty">
        アンカーリンクボタンはまだ登録されていません。テーマエディタからブロックを追加してください。
      </p>
    {%- else -%}
      <nav class="alsel-anchor-link-buttons__list" aria-label="{{ aria_label }}">
        {%- for block in section.blocks -%}
          {%- assign btn_label = block.settings.label | escape -%}
          <a
            href="{{ block.settings.anchor_id }}"
            class="alsel-anchor-link-buttons__btn"
            aria-label="{{ btn_label }}へ移動"
            {{ block.shopify_attributes }}
          >
            {%- if block.settings.icon != blank -%}
              <span class="alsel-anchor-link-buttons__icon" aria-hidden="true">{{ block.settings.icon }}</span>
            {%- endif -%}
            <span class="alsel-anchor-link-buttons__label">{{ block.settings.label }}</span>
            {%- if section.settings.show_arrow -%}
              <span class="alsel-anchor-link-buttons__arrow" aria-hidden="true">▼</span>
            {%- endif -%}
          </a>
        {%- endfor -%}
      </nav>
    {%- endif -%}
  </div>
</section>

<style>
  .alsel-anchor-link-buttons {
    --btn-bg: {{ section.settings.btn_bg }};
    --btn-color: {{ section.settings.btn_color }};
    --btn-border: {{ section.settings.btn_border }};
    --btn-radius: {{ section.settings.btn_radius }}px;
    --section-bg: {{ section.settings.section_bg }};
    padding: 1.5rem 1rem;
    background: var(--section-bg);
    box-sizing: border-box;
  }
  .alsel-anchor-link-buttons--sticky {
    position: sticky;
    top: 0;
    z-index: 50;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
  }
  .alsel-anchor-link-buttons__inner {
    max-width: 1100px;
    margin: 0 auto;
  }
  .alsel-anchor-link-buttons__heading {
    font-size: 1.1rem;
    font-weight: 700;
    text-align: center;
    margin: 0 0 1rem;
    color: #1f2937;
  }
  .alsel-anchor-link-buttons__empty {
    text-align: center;
    color: #888;
    padding: 2rem 0;
    margin: 0;
  }
  .alsel-anchor-link-buttons__list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    justify-content: center;
  }
  .alsel-anchor-link-buttons--scroll .alsel-anchor-link-buttons__list {
    flex-wrap: nowrap;
    overflow-x: auto;
    justify-content: flex-start;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: thin;
    padding-bottom: 0.25rem;
  }
  .alsel-anchor-link-buttons--grid .alsel-anchor-link-buttons__list {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.6rem;
  }
  .alsel-anchor-link-buttons__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
    padding: 0.7rem 1.1rem;
    background: var(--btn-bg);
    color: var(--btn-color);
    border: 1px solid var(--btn-border);
    border-radius: var(--btn-radius);
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 700;
    line-height: 1.3;
    white-space: nowrap;
    transition: transform 0.15s ease, box-shadow 0.15s ease, opacity 0.15s ease;
    flex-shrink: 0;
  }
  .alsel-anchor-link-buttons__btn:hover,
  .alsel-anchor-link-buttons__btn:focus {
    transform: translateY(-2px);
    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.08);
    opacity: 0.95;
  }
  .alsel-anchor-link-buttons--grid .alsel-anchor-link-buttons__btn {
    white-space: normal;
  }
  .alsel-anchor-link-buttons__icon {
    font-size: 1.05rem;
    line-height: 1;
  }
  .alsel-anchor-link-buttons__arrow {
    font-size: 0.65rem;
    opacity: 0.7;
  }
  @media (min-width: 750px) {
    .alsel-anchor-link-buttons {
      padding: 2rem 2rem;
    }
    .alsel-anchor-link-buttons__heading {
      font-size: 1.25rem;
    }
    .alsel-anchor-link-buttons__btn {
      padding: 0.85rem 1.5rem;
      font-size: 1rem;
    }
    .alsel-anchor-link-buttons--grid .alsel-anchor-link-buttons__list {
      grid-template-columns: repeat(4, 1fr);
    }
  }
</style>

{% schema %}
{
  "name": "アンカーリンクボタン群",
  "tag": "section",
  "class": "alsel-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "セクション見出し",
      "default": "目次",
      "info": "空欄にすると見出しは非表示になります"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "レイアウト",
      "options": [
        { "value": "wrap", "label": "横並び(折り返しあり)" },
        { "value": "scroll", "label": "横スクロール" },
        { "value": "grid", "label": "グリッド(2列 / PC は 4列)" }
      ],
      "default": "wrap"
    },
    {
      "type": "checkbox",
      "id": "is_sticky",
      "label": "スクロール時に上部に固定する",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_arrow",
      "label": "ボタンに下向き矢印を表示する",
      "default": true
    },
    {
      "type": "header",
      "content": "デザイン設定"
    },
    {
      "type": "color",
      "id": "section_bg",
      "label": "セクション背景色",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "btn_bg",
      "label": "ボタン背景色",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "btn_color",
      "label": "ボタン文字色",
      "default": "#1f2937"
    },
    {
      "type": "color",
      "id": "btn_border",
      "label": "ボタン枠線色",
      "default": "#d1d5db"
    },
    {
      "type": "range",
      "id": "btn_radius",
      "label": "ボタンの角丸",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "default": 8
    }
  ],
  "blocks": [
    {
      "type": "anchor_button",
      "name": "アンカーリンクボタン",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "ボタンの文字",
          "default": "セクション名",
          "info": "短く分かりやすい文字を入力してください"
        },
        {
          "type": "text",
          "id": "anchor_id",
          "label": "リンク先 ID",
          "default": "#section",
          "info": "移動したいセクションの ID を # 付きで入力します(例: #features)"
        },
        {
          "type": "text",
          "id": "icon",
          "label": "アイコン(絵文字)",
          "info": "任意。絵文字を 1 文字入力できます(例: ⭐ / 📦 / ❓)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "ALSEL監修 / アンカーリンクボタン群(目次ナビ)",
      "settings": {
        "heading": "このページの目次",
        "layout": "wrap",
        "is_sticky": false,
        "show_arrow": true
      },
      "blocks": [
        {
          "type": "anchor_button",
          "settings": {
            "label": "商品の特徴",
            "anchor_id": "#features",
            "icon": "⭐"
          }
        },
        {
          "type": "anchor_button",
          "settings": {
            "label": "お客様レビュー",
            "anchor_id": "#reviews",
            "icon": "💬"
          }
        },
        {
          "type": "anchor_button",
          "settings": {
            "label": "送料について",
            "anchor_id": "#shipping",
            "icon": "📦"
          }
        },
        {
          "type": "anchor_button",
          "settings": {
            "label": "よくあるご質問",
            "anchor_id": "#faq",
            "icon": "❓"
          }
        }
      ]
    }
  ]
}
{% endschema %}