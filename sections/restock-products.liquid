{% comment %}
============================================================
セクション名: 再入荷商品一覧
用途: 在庫切れから復活した人気商品をまとめて訴求し、購入機会を逃さないようにする
推奨設置場所: トップページの中段・コレクションページ上部・新着商品の近く
カスタマイズポイント:
  - セクション見出し・サブコピー
  - 表示する商品(コレクション選択 or ブロックで個別指定)
  - 「再入荷」バッジの文字・色
  - PC 時の表示列数(2 / 3 / 4列)
  - 価格表示の有無
  - 背景色・文字色
注意点:
  - コレクションを指定する場合は「再入荷」専用のコレクションを事前に作成しておくこと
  - 商品画像は正方形(1:1)で揃えるとレイアウトが綺麗になる
  - 在庫切れ商品も表示対象に含まれるため、必要に応じて在庫フィルタを利用する
動作確認バージョン: Online Store 2.0
ライセンス: ALSEL Original
============================================================
{% endcomment %}

<section class="alsel-restock-products" aria-label="{{ section.settings.heading | escape }}">
  <div class="alsel-restock-products__inner">
    {%- if section.settings.heading != blank -%}
      <h2 class="alsel-restock-products__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}
    {%- if section.settings.subheading != blank -%}
      <p class="alsel-restock-products__sub">{{ section.settings.subheading }}</p>
    {%- endif -%}

    <div class="alsel-restock-products__grid">
      {%- assign source = section.settings.product_source -%}
      {%- if source == 'collection' and section.settings.collection != blank -%}
        {%- assign limit = section.settings.product_limit | times: 1 -%}
        {%- for product in section.settings.collection.products limit: limit -%}
          <article class="alsel-restock-products__card">
            <a class="alsel-restock-products__link" href="{{ product.url }}" aria-label="{{ product.title | escape }}">
              <div class="alsel-restock-products__media">
                <span class="alsel-restock-products__badge">{{ section.settings.badge_text }}</span>
                {%- if product.featured_image != blank -%}
                  {%- assign alt_1 = product.title | escape -%}
{{ product.featured_image | image_url: width: 600 | image_tag: loading: 'lazy', class: 'alsel-restock-products__image', alt: alt_1, sizes: '(min-width: 750px) 25vw, 50vw', widths: '300, 600, 900' }}
                {%- else -%}
                  <div class="alsel-restock-products__image alsel-restock-products__image--empty" aria-hidden="true"></div>
                {%- endif -%}
              </div>
              <h3 class="alsel-restock-products__title">{{ product.title | escape }}</h3>
              {%- if section.settings.show_price -%}
                <p class="alsel-restock-products__price">{{ product.price | money }}</p>
              {%- endif -%}
            </a>
          </article>
        {%- endfor -%}
      {%- else -%}
        {%- if section.blocks.size == 0 -%}
    <p class="alsel-restock-products__empty" style="text-align:center;color:#888;padding:2rem 0;">表示する項目をテーマエディタからブロックとして追加してください。</p>
  {%- endif -%}
        {%- for block in section.blocks -%}
          {%- assign p = block.settings.product -%}
          <article class="alsel-restock-products__card" {{ block.shopify_attributes }}>
            {%- if p != blank -%}
              <a class="alsel-restock-products__link" href="{{ p.url }}" aria-label="{{ p.title | escape }}">
                <div class="alsel-restock-products__media">
                  <span class="alsel-restock-products__badge">{{ section.settings.badge_text }}</span>
                  {%- if p.featured_image != blank -%}
                    {%- assign alt_2 = p.title | escape -%}
{{ p.featured_image | image_url: width: 600 | image_tag: loading: 'lazy', class: 'alsel-restock-products__image', alt: alt_2, sizes: '(min-width: 750px) 25vw, 50vw', widths: '300, 600, 900' }}
                  {%- else -%}
                    <div class="alsel-restock-products__image alsel-restock-products__image--empty" aria-hidden="true"></div>
                  {%- endif -%}
                </div>
                <h3 class="alsel-restock-products__title">{{ p.title | escape }}</h3>
                {%- if section.settings.show_price -%}
                  <p class="alsel-restock-products__price">{{ p.price | money }}</p>
                {%- endif -%}
              </a>
            {%- else -%}
              <div class="alsel-restock-products__placeholder" aria-hidden="true">
                <div class="alsel-restock-products__media">
                  <span class="alsel-restock-products__badge">{{ section.settings.badge_text }}</span>
                  <div class="alsel-restock-products__image alsel-restock-products__image--empty"></div>
                </div>
                <h3 class="alsel-restock-products__title">商品を選択してください</h3>
              </div>
            {%- endif -%}
          </article>
        {%- endfor -%}
      {%- endif -%}
    </div>

    {%- if section.settings.view_more_text != blank and section.settings.view_more_link != blank -%}
      <div class="alsel-restock-products__more">
        <a class="alsel-restock-products__more-link" href="{{ section.settings.view_more_link }}">
          {{ section.settings.view_more_text }}
        </a>
      </div>
    {%- endif -%}
  </div>
</section>

<style>
  .alsel-restock-products { padding: 3rem 1rem; background: {{ section.settings.bg_color }}; color: {{ section.settings.text_color }}; }
  .alsel-restock-products__inner { max-width: 1200px; margin: 0 auto; }
  .alsel-restock-products__heading { font-size: clamp(1.4rem, 4vw, 2.2rem); font-weight: 700; text-align: center; margin: 0 0 0.75rem; }
  .alsel-restock-products__sub { font-size: 0.95rem; line-height: 1.7; text-align: center; margin: 0 0 2rem; opacity: 0.8; }
  .alsel-restock-products__grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1rem; }
  .alsel-restock-products__card { background: #fff; border-radius: 12px; overflow: hidden; box-shadow: 0 2px 8px rgba(0,0,0,0.06); transition: transform 0.2s ease, box-shadow 0.2s ease; }
  .alsel-restock-products__card:hover { transform: translateY(-3px); box-shadow: 0 6px 16px rgba(0,0,0,0.1); }
  .alsel-restock-products__link { display: block; color: inherit; text-decoration: none; }
  .alsel-restock-products__media { position: relative; aspect-ratio: 1 / 1; overflow: hidden; background: #f1f5f9; }
  .alsel-restock-products__image { width: 100%; height: 100%; object-fit: cover; display: block; }
  .alsel-restock-products__image--empty { background: linear-gradient(135deg, #e2e8f0, #f1f5f9); }
  .alsel-restock-products__badge { position: absolute; top: 0.5rem; left: 0.5rem; z-index: 1; background: {{ section.settings.badge_bg }}; color: {{ section.settings.badge_color }}; font-size: 0.75rem; font-weight: 700; padding: 0.25rem 0.6rem; border-radius: 9999px; letter-spacing: 0.04em; }
  .alsel-restock-products__title { font-size: 0.9rem; font-weight: 600; line-height: 1.5; margin: 0.75rem 0.75rem 0.25rem; color: #1e293b; }
  .alsel-restock-products__price { font-size: 0.95rem; font-weight: 700; margin: 0 0.75rem 0.75rem; color: #0f172a; }
  .alsel-restock-products__placeholder { padding-bottom: 0.75rem; }
  .alsel-restock-products__more { text-align: center; margin-top: 2rem; }
  .alsel-restock-products__more-link { display: inline-block; padding: 0.85rem 2rem; background: {{ section.settings.button_bg }}; color: {{ section.settings.button_color }}; border-radius: 9999px; font-weight: 700; text-decoration: none; font-size: 0.95rem; }
  .alsel-restock-products__more-link:hover { opacity: 0.85; }
  @media (min-width: 750px) {
    .alsel-restock-products { padding: 5rem 2rem; }
    .alsel-restock-products__grid { grid-template-columns: repeat({{ section.settings.columns_pc }}, 1fr); gap: 1.5rem; }
    .alsel-restock-products__title { font-size: 1rem; margin: 1rem 1rem 0.4rem; }
    .alsel-restock-products__price { font-size: 1.05rem; margin: 0 1rem 1rem; }
  }
</style>

{% schema %}
{
  "name": "再入荷商品一覧",
  "tag": "section",
  "class": "alsel-section",
  "settings": [
    { "type": "header", "content": "見出し設定" },
    { "type": "text", "id": "heading", "label": "セクション見出し", "default": "再入荷商品" },
    { "type": "textarea", "id": "subheading", "label": "サブコピー", "default": "ご好評につき完売していた人気商品が再入荷した。なくなり次第終了。" },
    { "type": "header", "content": "表示する商品" },
    { "type": "select", "id": "product_source", "label": "商品の指定方法",
      "options": [
        { "value": "collection", "label": "コレクションから自動表示" },
        { "value": "manual", "label": "手動で個別指定(ブロック)" }
      ],
      "default": "collection",
      "info": "コレクションを使う場合は事前に再入荷商品をまとめたコレクションを用意する" },
    { "type": "collection", "id": "collection", "label": "表示するコレクション", "info": "「商品の指定方法」がコレクションの場合に使用" },
    { "type": "range", "id": "product_limit", "label": "最大表示件数", "min": 2, "max": 24, "step": 1, "default": 8 },
    { "type": "header", "content": "バッジ設定" },
    { "type": "text", "id": "badge_text", "label": "バッジの文字", "default": "再入荷" },
    { "type": "color", "id": "badge_bg", "label": "バッジ背景色", "default": "#dc2626" },
    { "type": "color", "id": "badge_color", "label": "バッジ文字色", "default": "#ffffff" },
    { "type": "header", "content": "レイアウト" },
    { "type": "select", "id": "columns_pc", "label": "PC 時の列数",
      "options": [
        { "value": "2", "label": "2列" },
        { "value": "3", "label": "3列" },
        { "value": "4", "label": "4列" }
      ],
      "default": "4" },
    { "type": "checkbox", "id": "show_price", "label": "価格を表示する", "default": true },
    { "type": "header", "content": "もっと見るボタン" },
    { "type": "text", "id": "view_more_text", "label": "ボタンの文字", "default": "すべての再入荷商品を見る" },
    { "type": "url", "id": "view_more_link", "label": "ボタンのリンク先" },
    { "type": "color", "id": "button_bg", "label": "ボタン背景色", "default": "#0f172a" },
    { "type": "color", "id": "button_color", "label": "ボタン文字色", "default": "#ffffff" },
    { "type": "header", "content": "配色" },
    { "type": "color", "id": "bg_color", "label": "セクション背景色", "default": "#f8fafc" },
    { "type": "color", "id": "text_color", "label": "文字色", "default": "#0f172a" }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "商品",
      "limit": 12,
      "settings": [
        { "type": "product", "id": "product", "label": "商品", "info": "再入荷した商品を選択する" }
      ]
    }
  ],
  "presets": [
    {
      "name": "ALSEL監修 / 再入荷商品一覧",
      "settings": {
        "heading": "再入荷商品",
        "subheading": "ご好評につき完売していた人気商品が再入荷した。なくなり次第終了。",
        "product_source": "collection",
        "product_limit": 8,
        "badge_text": "再入荷",
        "columns_pc": "4",
        "show_price": true,
        "view_more_text": "すべての再入荷商品を見る"
      }
    }
  ]
}
{% endschema %}