      "blocks": [
        { "type": "problem", "settings": { "highlight": "毎朝", "text": "鏡を見るたびにため息が出てしまいます。" } },
        { "type": "problem", "settings": { "highlight": "色々試したけど", "text": "どれも続かず、効果も実感できませんでした。" } },
        { "type": "problem", "settings": { "highlight": "忙しくて", "text": "ケアに時間をかけられず、諦めかけています。" } },
        { "type": "problem", "settings": { "highlight": "年齢のせい?", "text": "最近、写真に写る自分に自信が持てません。" } },
        { "type": "problem", "settings": { "highlight": "本気で", "text": "今度こそ、本物の商品に出会いたいです。" } }
      ]
    }
  ]
}
{% endschema %}