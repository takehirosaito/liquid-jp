{% comment %}
============================================================
セクション名: アコーディオン商品説明
用途: 長い商品説明や仕様情報を、見出しごとに折りたためる形で整理して見せる。情報量が多くても見やすい
推奨設置場所: 商品ページの説明欄下、トップページの FAQ 風コーナー、LP の詳細説明部
カスタマイズポイント:
  - セクション見出し・リード文
  - アコーディオン項目(タイトル・本文)をブロックで自由に追加
  - 初期表示で開いておく項目の指定
  - 文字色・アクセントカラー・背景色
注意点:
  - <details> / <summary> を使うため JavaScript 不要で動作する
  - ブロックは 1〜10 個程度を推奨
  - 本文には改行を含むテキストを入れても表示崩れしない
動作確認バージョン: Online Store 2.0
ライセンス: ALSEL Original
============================================================
{% endcomment %}

{%- assign root_label = section.settings.heading | default: 'アコーディオン商品説明' | escape -%}

<section class="alsel-accordion-specs" aria-label="{{ root_label }}">
  <div class="alsel-accordion-specs__inner">
    {%- if section.settings.heading != blank -%}
      <h2 class="alsel-accordion-specs__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}
    {%- if section.settings.lead != blank -%}
      <p class="alsel-accordion-specs__lead">{{ section.settings.lead }}</p>
    {%- endif -%}

    {%- if section.blocks.size == 0 -%}
      <p class="alsel-accordion-specs__empty">
        表示できる項目はまだ登録されていません。テーマエディタからブロックを追加してください。
      </p>
    {%- else -%}
      <div class="alsel-accordion-specs__list">
        {%- for block in section.blocks -%}
          <details
            class="alsel-accordion-specs__item"
            {{ block.shopify_attributes }}
            {%- if block.settings.open_default %} open{%- endif -%}
          >
            <summary class="alsel-accordion-specs__summary">
              {%- if block.settings.label != blank -%}
                <span class="alsel-accordion-specs__label">{{ block.settings.label }}</span>
              {%- endif -%}
              <span class="alsel-accordion-specs__title">{{ block.settings.title }}</span>
              <span class="alsel-accordion-specs__icon" aria-hidden="true"></span>
            </summary>
            <div class="alsel-accordion-specs__body">
              {{ block.settings.body }}
            </div>
          </details>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

<style>
  .alsel-accordion-specs {
    --accent: {{ section.settings.accent_color }};
    --text: {{ section.settings.text_color }};
    --bg: {{ section.settings.bg_color }};
    --card: {{ section.settings.card_bg }};
    padding: 2.5rem 1rem;
    background: var(--bg);
    color: var(--text);
  }
  .alsel-accordion-specs__inner { max-width: 880px; margin: 0 auto; }
  .alsel-accordion-specs__heading {
    font-size: clamp(1.4rem, 4vw, 2rem);
    font-weight: 700;
    text-align: center;
    margin: 0 0 0.75rem;
    line-height: 1.4;
  }
  .alsel-accordion-specs__lead {
    text-align: center;
    font-size: 0.95rem;
    line-height: 1.7;
    color: #64748b;
    margin: 0 0 2rem;
  }
  .alsel-accordion-specs__empty {
    text-align: center;
    color: #888;
    padding: 2rem 0;
    font-size: 0.95rem;
  }
  .alsel-accordion-specs__list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .alsel-accordion-specs__item {
    background: var(--card);
    border: 1px solid #e5e7eb;
    border-radius: 10px;
    overflow: hidden;
    transition: box-shadow 0.2s ease, border-color 0.2s ease;
  }
  .alsel-accordion-specs__item[open] {
    border-color: var(--accent);
    box-shadow: 0 4px 14px rgba(0, 0, 0, 0.06);
  }
  .alsel-accordion-specs__summary {
    list-style: none;
    cursor: pointer;
    padding: 1.1rem 1.2rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 1rem;
    font-weight: 700;
    line-height: 1.5;
    user-select: none;
  }
  .alsel-accordion-specs__summary::-webkit-details-marker { display: none; }
  .alsel-accordion-specs__label {
    display: inline-block;
    padding: 0.2rem 0.6rem;
    background: var(--accent);
    color: #fff;
    border-radius: 4px;
    font-size: 0.75rem;
    font-weight: 700;
    flex-shrink: 0;
  }
  .alsel-accordion-specs__title { flex: 1; }
  .alsel-accordion-specs__icon {
    width: 14px;
    height: 14px;
    position: relative;
    flex-shrink: 0;
    transition: transform 0.2s ease;
  }
  .alsel-accordion-specs__icon::before,
  .alsel-accordion-specs__icon::after {
    content: '';
    position: absolute;
    background: var(--accent);
    border-radius: 1px;
    top: 50%;
    left: 50%;
  }
  .alsel-accordion-specs__icon::before {
    width: 14px; height: 2px; transform: translate(-50%, -50%);
  }
  .alsel-accordion-specs__icon::after {
    width: 2px; height: 14px; transform: translate(-50%, -50%);
    transition: transform 0.2s ease;
  }
  .alsel-accordion-specs__item[open] .alsel-accordion-specs__icon::after {
    transform: translate(-50%, -50%) scaleY(0);
  }
  .alsel-accordion-specs__body {
    padding: 0 1.2rem 1.2rem;
    font-size: 0.95rem;
    line-height: 1.85;
    color: #475569;
    border-top: 1px solid #f1f5f9;
    padding-top: 1rem;
    white-space: pre-wrap;
  }
  .alsel-accordion-specs__body :first-child { margin-top: 0; }
  .alsel-accordion-specs__body :last-child { margin-bottom: 0; }
  @media (min-width: 750px) {
    .alsel-accordion-specs { padding: 4rem 2rem; }
    .alsel-accordion-specs__summary { padding: 1.25rem 1.5rem; font-size: 1.05rem; }
    .alsel-accordion-specs__body { padding: 0 1.5rem 1.5rem; padding-top: 1.1rem; font-size: 1rem; }
  }
</style>

{% schema %}
{
  "name": "アコーディオン商品説明",
  "tag": "section",
  "class": "alsel-section",
  "settings": [
    { "type": "text", "id": "heading", "label": "セクション見出し", "default": "商品の詳細情報" },
    { "type": "textarea", "id": "lead", "label": "リード文", "default": "気になる項目をタップすると詳細をご覧いただけます。" },
    { "type": "color", "id": "bg_color", "label": "背景色", "default": "#f8fafc" },
    { "type": "color", "id": "card_bg", "label": "カード背景色", "default": "#ffffff" },
    { "type": "color", "id": "text_color", "label": "文字色", "default": "#0f172a" },
    { "type": "color", "id": "accent_color", "label": "アクセントカラー", "default": "#6d28d9", "info": "ラベル背景・開閉アイコン・開封時の枠線に使用します" }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "アコーディオン項目",
      "settings": [
        { "type": "text", "id": "label", "label": "ラベル(任意)", "info": "「仕様」「成分」「注意」など、短いタグです。空にすると非表示になります" },
        { "type": "text", "id": "title", "label": "見出し", "default": "項目タイトル" },
        { "type": "richtext", "id": "body", "label": "本文", "default": "<p>項目の詳細説明をこちらに入力します。リッチテキストに対応しているため、リンクや強調も使えます。</p>" },
        { "type": "checkbox", "id": "open_default", "label": "初期状態で開いておく", "default": false, "info": "重要な項目はオンにすると最初から開いた状態で表示されます" }
      ]
    }
  ],
  "presets": [
    {
      "name": "ALSEL監修 / アコーディオン商品説明(縦並びリスト)",
      "settings": {
        "heading": "商品の詳細情報",
        "lead": "気になる項目をタップすると詳細をご覧いただけます。"
      },
      "blocks": [
        { "type": "item", "settings": { "label": "仕様", "title": "サイズ・素材について", "body": "<p>サイズ:幅 30cm × 高さ 40cm × 奥行 10cm<br>素材:天然木(オーク材)・スチール脚<br>重量:約 3.2kg</p>", "open_default": true } },
        { "type": "item", "settings": { "label": "使い方", "title": "ご使用方法", "body": "<p>付属の説明書に沿って組み立ててご使用ください。組み立て時間は約 15 分が目安となります。</p>" } },
        { "type": "item", "settings": { "label": "配送", "title": "配送・お届けについて", "body": "<p>ご注文確定から 3〜5 営業日でお届けします。配送業者はヤマト運輸を予定しています。</p>" } },
        { "type": "item", "settings": { "label": "注意", "title": "ご使用上の注意", "body": "<p>直射日光の当たる場所や湿気の多い場所での保管はお避けください。長くお使いいただくために定期的なお手入れをおすすめします。</p>" } }
      ]
    }
  ]
}
{% endschema %}