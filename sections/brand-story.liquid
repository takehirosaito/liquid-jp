    },
    {
      "type": "header",
      "content": "署名"
    },
    {
      "type": "text",
      "id": "author_role",
      "label": "肩書き",
      "default": "代表取締役"
    },
    {
      "type": "text",
      "id": "author_name",
      "label": "代表者名",
      "default": "山田 太郎"
    },
    {
      "type": "header",
      "content": "ボタン"
