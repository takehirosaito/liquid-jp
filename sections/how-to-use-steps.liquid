{% comment %}
============================================================
セクション名: 使い方3ステップ
用途: 商品やサービスの使い方を、画像付きの3ステップで分かりやすく伝える定番セクション
推奨設置場所: 商品ページの説明欄下・LP の途中・トップページの特集枠
カスタマイズポイント:
  - セクション見出し・リード文
  - 各ステップの画像・ステップ名・本文
  - ステップ番号の色・背景色・アクセントカラー
  - ブロック追加で 3 ステップ以上にも対応(推奨 3〜5 個)
注意点:
  - 各ステップ画像は正方形または横長(推奨 800 × 800px、JPEG または PNG)
  - ブロックは最低 1 個から動作する。推奨は 3 個
  - ステップ番号はブロックの並び順に自動で連番が振られる
動作確認バージョン: Online Store 2.0
ライセンス: ALSEL Original
============================================================
{% endcomment %}

<section class="alsel-how-to-use-steps" aria-label="{{ section.settings.heading | escape | default: '使い方の手順' }}">
  <div class="alsel-how-to-use-steps__inner">
    {%- if section.settings.heading != blank -%}
      <h2 class="alsel-how-to-use-steps__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}
    {%- if section.settings.lead != blank -%}
      <p class="alsel-how-to-use-steps__lead">{{ section.settings.lead }}</p>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <ol class="alsel-how-to-use-steps__list">
        {%- for block in section.blocks -%}
          <li class="alsel-how-to-use-steps__item" {{ block.shopify_attributes }}>
            <div class="alsel-how-to-use-steps__media">
              {%- if block.settings.image != blank -%}
                {%- assign alt_1 = block.settings.title | escape -%}
{{ block.settings.image
                  | image_url: width: 800
                  | image_tag:
                    loading: 'lazy',
                    class: 'alsel-how-to-use-steps__image',
                    alt: alt_1,
                    widths: '300, 600, 800',
                    sizes: '(min-width: 750px) 33vw, 90vw' }}
              {%- else -%}
                <div class="alsel-how-to-use-steps__placeholder" aria-hidden="true">No Image</div>
              {%- endif -%}
              <span class="alsel-how-to-use-steps__badge" aria-label="ステップ{{ forloop.index }}">
                <span class="alsel-how-to-use-steps__badge-label">STEP</span>
                <span class="alsel-how-to-use-steps__badge-num">{{ forloop.index }}</span>
              </span>
            </div>
            <div class="alsel-how-to-use-steps__text">
              {%- if block.settings.title != blank -%}
                <h3 class="alsel-how-to-use-steps__title">{{ block.settings.title }}</h3>
              {%- endif -%}
              {%- if block.settings.body != blank -%}
                <p class="alsel-how-to-use-steps__body">{{ block.settings.body }}</p>
              {%- endif -%}
            </div>
          </li>
        {%- endfor -%}
      </ol>
    {%- endif -%}
  </div>
</section>

<style>
  .alsel-how-to-use-steps {
    --alsel-htus-bg: {{ section.settings.bg_color }};
    --alsel-htus-text: {{ section.settings.text_color }};
    --alsel-htus-accent: {{ section.settings.accent_color }};
    --alsel-htus-badge-text: {{ section.settings.badge_text_color }};
    padding: 3rem 1rem;
    background: var(--alsel-htus-bg);
    color: var(--alsel-htus-text);
  }
  .alsel-how-to-use-steps__inner { max-width: 1100px; margin: 0 auto; }
  .alsel-how-to-use-steps__heading {
    font-size: clamp(1.5rem, 4.5vw, 2.4rem);
    font-weight: 700;
    text-align: center;
    margin: 0 0 0.75rem;
    line-height: 1.4;
  }
  .alsel-how-to-use-steps__lead {
    text-align: center;
    font-size: 0.95rem;
    line-height: 1.7;
    margin: 0 auto 2.5rem;
    max-width: 640px;
    color: inherit;
    opacity: 0.85;
  }
  .alsel-how-to-use-steps__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }
  .alsel-how-to-use-steps__item {
    background: #ffffff;
    border-radius: 14px;
    overflow: hidden;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.06);
    display: flex;
    flex-direction: column;
  }
  .alsel-how-to-use-steps__media {
    position: relative;
    aspect-ratio: 1 / 1;
    background: #f1f5f9;
    overflow: hidden;
  }
  .alsel-how-to-use-steps__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .alsel-how-to-use-steps__placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #94a3b8;
    font-size: 0.9rem;
  }
  .alsel-how-to-use-steps__badge {
    position: absolute;
    top: 12px;
    left: 12px;
    display: inline-flex;
    align-items: baseline;
    gap: 0.35rem;
    padding: 0.4rem 0.8rem;
    background: var(--alsel-htus-accent);
    color: var(--alsel-htus-badge-text);
    border-radius: 9999px;
    font-weight: 700;
    box-shadow: 0 2px 6px rgba(0, 0, 0, 0.15);
  }
  .alsel-how-to-use-steps__badge-label {
    font-size: 0.7rem;
    letter-spacing: 0.08em;
  }
  .alsel-how-to-use-steps__badge-num {
    font-size: 1.1rem;
    line-height: 1;
  }
  .alsel-how-to-use-steps__text { padding: 1.25rem 1.25rem 1.5rem; }
  .alsel-how-to-use-steps__title {
    font-size: 1.15rem;
    font-weight: 700;
    margin: 0 0 0.6rem;
    color: #0f172a;
    line-height: 1.5;
  }
  .alsel-how-to-use-steps__body {
    font-size: 0.95rem;
    line-height: 1.8;
    margin: 0;
    color: #475569;
  }
  @media (min-width: 750px) {
    .alsel-how-to-use-steps { padding: 5rem 2rem; }
    .alsel-how-to-use-steps__lead { margin-bottom: 3.5rem; font-size: 1rem; }
    .alsel-how-to-use-steps__list {
      grid-template-columns: repeat(3, 1fr);
      gap: 1.75rem;
    }
    .alsel-how-to-use-steps__title { font-size: 1.25rem; }
  }
</style>

{% schema %}
{
  "name": "使い方3ステップ",
  "tag": "section",
  "class": "alsel-section",
  "settings": [
    { "type": "text", "id": "heading", "label": "セクション見出し", "default": "かんたん3ステップの使い方" },
    { "type": "textarea", "id": "lead", "label": "リード文", "default": "はじめてでも迷わず使えるように、3つのステップでわかりやすく解説します。", "info": "見出しの下に表示される補足文。空欄にすると非表示になる。" },
    { "type": "color", "id": "bg_color", "label": "背景色", "default": "#f8fafc" },
    { "type": "color", "id": "text_color", "label": "見出し・リード文の文字色", "default": "#0f172a" },
    { "type": "color", "id": "accent_color", "label": "ステップ番号バッジの背景色", "default": "#6d28d9" },
    { "type": "color", "id": "badge_text_color", "label": "ステップ番号バッジの文字色", "default": "#ffffff" }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "ステップ",
      "limit": 6,
      "settings": [
        { "type": "image_picker", "id": "image", "label": "ステップ画像", "info": "推奨 800 × 800px、JPEG または PNG。正方形が見栄えよく収まる。" },
        { "type": "text", "id": "title", "label": "ステップのタイトル", "default": "手順のタイトル" },
        { "type": "textarea", "id": "body", "label": "ステップの説明文", "default": "ここに手順の説明文を入れる。短く具体的に書くと伝わりやすい。" }
      ]
    }
  ],
  "presets": [
    {
      "name": "ALSEL監修 / 使い方3ステップ",
      "settings": {
        "heading": "かんたん3ステップの使い方",
        "lead": "はじめてでも迷わず使えるように、3つのステップでわかりやすく解説します。"
      },
      "blocks": [
        { "type": "step", "settings": { "title": "商品を手に取る", "body": "パッケージから本体を取り出し、状態を確認します。" } },
        { "type": "step", "settings": { "title": "適量を使用する", "body": "目安量を守って肌や対象物に丁寧になじませる。" } },
        { "type": "step", "settings": { "title": "仕上げを確認する", "body": "全体に行き渡ったら完了。毎日続けることで効果を実感できます。" } }
      ]
    }
  ]
}
{% endschema %}