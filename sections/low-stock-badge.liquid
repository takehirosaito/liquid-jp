{% comment %}
============================================================
セクション名: 在庫残りわずか表示
用途: 商品ページや LP で「残りわずか」「在庫◯個」など希少性を訴求し、購入を後押しする
推奨設置場所: 商品ページの購入ボタン付近、LP の CTA 直前
カスタマイズポイント:
  - 見出し・メッセージ文・在庫数の数値
  - バッジの色(背景色・文字色)
  - 警告アイコンの表示有無
  - 在庫プログレスバーの表示有無と総数
  - アニメーション(点滅)の有無
注意点:
  - 在庫数はテーマエディタから手動入力する数値である(Shopify の実在庫とは連動しない)
  - 実在庫連動は別途カスタム開発が必要
  - 過度な訴求は景品表示法に抵触する恐れがあるため、虚偽の在庫数は記載しないこと
動作確認バージョン: Online Store 2.0
ライセンス: ALSEL Original
============================================================
{% endcomment %}

{%- assign stock_now = section.settings.stock_count | times: 1 -%}
{%- assign stock_total = section.settings.stock_total | times: 1 -%}
{%- if stock_total > 0 -%}
  {%- assign stock_percent = stock_now | times: 100.0 | divided_by: stock_total -%}
{%- else -%}
  {%- assign stock_percent = 0 -%}
{%- endif -%}

<section class="alsel-low-stock-badge" aria-label="{{ section.settings.heading | escape }}">
  <div class="alsel-low-stock-badge__inner">
    <div class="alsel-low-stock-badge__badge{%- if section.settings.blink %} alsel-low-stock-badge__badge--blink{%- endif -%}">
      {%- if section.settings.show_icon -%}
        <span class="alsel-low-stock-badge__icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" width="20" height="20">
            <path d="M12 2L1 21h22L12 2zm0 6l7.5 13h-15L12 8zm-1 4v4h2v-4h-2zm0 5v2h2v-2h-2z" fill="currentColor"/>
          </svg>
        </span>
      {%- endif -%}
      <span class="alsel-low-stock-badge__label">{{ section.settings.badge_text }}</span>
    </div>

    {%- if section.settings.heading != blank -%}
      <h2 class="alsel-low-stock-badge__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    {%- if section.settings.show_count -%}
      <p class="alsel-low-stock-badge__count">
        {{ section.settings.count_prefix }}
        <span class="alsel-low-stock-badge__number">{{ stock_now }}</span>
        <span class="alsel-low-stock-badge__unit">{{ section.settings.count_unit }}</span>
      </p>
    {%- endif -%}

    {%- if section.settings.show_bar and stock_total > 0 -%}
      <div class="alsel-low-stock-badge__bar" role="progressbar" aria-valuenow="{{ stock_now }}" aria-valuemin="0" aria-valuemax="{{ stock_total }}">
        <div class="alsel-low-stock-badge__bar-fill" style="width: {{ stock_percent }}%;"></div>
      </div>
      <p class="alsel-low-stock-badge__bar-text">
        全 {{ stock_total }} {{ section.settings.count_unit }}のうち、残り <strong>{{ stock_now }}</strong> {{ section.settings.count_unit }}です。
      </p>
    {%- endif -%}

    {%- if section.settings.message != blank -%}
      <p class="alsel-low-stock-badge__message">{{ section.settings.message }}</p>
    {%- endif -%}

    {%- if section.settings.cta_text != blank and section.settings.cta_link != blank -%}
      <a class="alsel-low-stock-badge__cta" href="{{ section.settings.cta_link }}">
        {{ section.settings.cta_text }}
      </a>
    {%- endif -%}
  </div>
</section>

<style>
  .alsel-low-stock-badge {
    --accent: {{ section.settings.badge_bg }};
    --accent-text: {{ section.settings.badge_color }};
    --panel-bg: {{ section.settings.panel_bg }};
    --text-color: {{ section.settings.text_color }};
    padding: 2rem 1rem;
  }
  .alsel-low-stock-badge__inner {
    max-width: 600px;
    margin: 0 auto;
    padding: 1.75rem 1.5rem;
    background: var(--panel-bg);
    border: 2px solid var(--accent);
    border-radius: 14px;
    text-align: center;
    color: var(--text-color);
  }
  .alsel-low-stock-badge__badge {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.4rem 1rem;
    background: var(--accent);
    color: var(--accent-text);
    border-radius: 9999px;
    font-size: 0.85rem;
    font-weight: 700;
    margin-bottom: 1rem;
  }
  .alsel-low-stock-badge__badge--blink {
    animation: alsel-low-stock-blink 1.6s ease-in-out infinite;
  }
  @keyframes alsel-low-stock-blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.55; }
  }
  .alsel-low-stock-badge__icon {
    display: inline-flex;
    align-items: center;
  }
  .alsel-low-stock-badge__heading {
    font-size: clamp(1.15rem, 3.5vw, 1.5rem);
    font-weight: 700;
    margin: 0 0 0.75rem;
    line-height: 1.4;
  }
  .alsel-low-stock-badge__count {
    margin: 0 0 1rem;
    font-size: 1rem;
  }
  .alsel-low-stock-badge__number {
    color: var(--accent);
    font-size: clamp(1.6rem, 5vw, 2.2rem);
    font-weight: 700;
    margin: 0 0.25rem;
    vertical-align: -0.05em;
  }
  .alsel-low-stock-badge__unit {
    font-size: 0.95rem;
  }
  .alsel-low-stock-badge__bar {
    width: 100%;
    height: 10px;
    background: #e5e7eb;
    border-radius: 9999px;
    overflow: hidden;
    margin: 0.75rem 0 0.5rem;
  }
  .alsel-low-stock-badge__bar-fill {
    height: 100%;
    background: var(--accent);
    transition: width 0.4s ease;
  }
  .alsel-low-stock-badge__bar-text {
    font-size: 0.85rem;
    color: #64748b;
    margin: 0 0 1rem;
  }
  .alsel-low-stock-badge__message {
    font-size: 0.95rem;
    line-height: 1.7;
    margin: 0 0 1.25rem;
  }
  .alsel-low-stock-badge__cta {
    display: inline-block;
    padding: 0.85rem 2rem;
    background: var(--accent);
    color: var(--accent-text);
    text-decoration: none;
    border-radius: 9999px;
    font-weight: 700;
    font-size: 0.95rem;
  }
  @media (min-width: 750px) {
    .alsel-low-stock-badge { padding: 3rem 2rem; }
    .alsel-low-stock-badge__inner { padding: 2.25rem 2rem; }
  }
</style>

{% schema %}
{
  "name": "在庫残りわずか表示",
  "tag": "section",
  "class": "alsel-section",
  "settings": [
    { "type": "text", "id": "badge_text", "label": "バッジの文字", "default": "残りわずか", "info": "バッジに表示する短い訴求文言です。" },
    { "type": "checkbox", "id": "show_icon", "label": "警告アイコンを表示する", "default": true },
    { "type": "checkbox", "id": "blink", "label": "バッジを点滅させる", "default": true, "info": "視認性を高めますが、控えめに使うことをおすすめします。" },
    { "type": "text", "id": "heading", "label": "見出し", "default": "ご注文はお早めにお願いします" },
    { "type": "checkbox", "id": "show_count", "label": "在庫数を表示する", "default": true },
    { "type": "text", "id": "count_prefix", "label": "在庫数の前置き文言", "default": "在庫はあと" },
    { "type": "number", "id": "stock_count", "label": "現在の在庫数", "default": 3, "info": "テーマエディタから手動入力する数値です。実在庫とは連動しません。" },
    { "type": "text", "id": "count_unit", "label": "在庫の単位", "default": "点" },
    { "type": "checkbox", "id": "show_bar", "label": "在庫プログレスバーを表示する", "default": true },
    { "type": "number", "id": "stock_total", "label": "在庫の総数(プログレスバー用)", "default": 30, "info": "プログレスバーの満タン基準値です。" },
    { "type": "textarea", "id": "message", "label": "補足メッセージ", "default": "人気商品のため、在庫が少なくなっております。再入荷の予定は未定ですので、お早めにご検討ください。" },
    { "type": "text", "id": "cta_text", "label": "ボタンの文字", "default": "今すぐ購入する" },
    { "type": "url", "id": "cta_link", "label": "ボタンのリンク先" },
    { "type": "header", "content": "デザイン設定" },
    { "type": "color", "id": "badge_bg", "label": "バッジ・アクセント色", "default": "#dc2626" },
    { "type": "color", "id": "badge_color", "label": "バッジ文字色", "default": "#ffffff" },
    { "type": "color", "id": "panel_bg", "label": "パネル背景色", "default": "#fff7ed" },
    { "type": "color", "id": "text_color", "label": "本文の文字色", "default": "#1f2937" }
  ],
  "presets": [
    {
      "name": "ALSEL監修 / 在庫残りわずか表示(訴求バッジ型)",
      "settings": {
        "badge_text": "残りわずか",
        "heading": "ご注文はお早めにお願いします",
        "count_prefix": "在庫はあと",
        "stock_count": 3,
        "count_unit": "点",
        "stock_total": 30,
        "message": "人気商品のため、在庫が少なくなっております。再入荷の予定は未定ですので、お早めにご検討ください。",
        "cta_text": "今すぐ購入する"
      }
    }
  ]
}
{% endschema %}