{% comment %}
============================================================
セクション名: 目次付きLPセクション
用途: 縦長LPの冒頭に設置し、各見出しへワンタップでジャンプできる目次を提供する。離脱率低減と読了率アップに効く定番パーツ
推奨設置場所: トップページ・LP ページのファーストビュー直後
カスタマイズポイント:
  - 見出し・サブコピー・強調バッジ
  - 目次ブロック(番号・タイトル・補足・ジャンプ先 ID)
  - 配色(背景・アクセント・帯)
  - 表示形式(番号付き / 矢印付き)
注意点:
  - ジャンプ先 ID は LP 内の別セクションで同じ ID を持つ要素に飛ぶ
  - ID は半角英数字・ハイフンのみ推奨(例: chapter-01)
  - LP の章数は 3〜10 個推奨
動作確認バージョン: Online Store 2.0
ライセンス: ALSEL Original
============================================================
{% endcomment %}

{%- assign s = section.settings -%}

<section class="alsel-lp-table-of-contents" aria-label="{{ s.heading | escape }}">
  <div class="alsel-lp-table-of-contents__inner">
    {%- if s.badge != blank -%}
      <span class="alsel-lp-table-of-contents__badge">{{ s.badge }}</span>
    {%- endif -%}

    {%- if s.heading != blank -%}
      <h2 class="alsel-lp-table-of-contents__heading">
        <span class="alsel-lp-table-of-contents__heading-mark">/</span>
        {{ s.heading }}
        <span class="alsel-lp-table-of-contents__heading-mark">\</span>
      </h2>
    {%- endif -%}

    {%- if s.subheading != blank -%}
      <p class="alsel-lp-table-of-contents__sub">{{ s.subheading }}</p>
    {%- endif -%}

    {%- if section.blocks.size == 0 -%}
      <p class="alsel-lp-table-of-contents__empty">
        目次の項目はまだ登録されていません。テーマエディタからブロックを追加してください。
      </p>
    {%- else -%}
      <ol class="alsel-lp-table-of-contents__list">
        {%- for block in section.blocks -%}
          {%- assign anchor = block.settings.anchor_id | strip | escape -%}
          {%- assign num = forloop.index | prepend: '0' | slice: -2, 2 -%}
          <li class="alsel-lp-table-of-contents__item" {{ block.shopify_attributes }}>
            <a class="alsel-lp-table-of-contents__link" href="#{{ anchor }}">
              <span class="alsel-lp-table-of-contents__num">{{ num }}</span>
              <span class="alsel-lp-table-of-contents__body">
                <span class="alsel-lp-table-of-contents__title">{{ block.settings.title }}</span>
                {%- if block.settings.note != blank -%}
                  <span class="alsel-lp-table-of-contents__note">{{ block.settings.note }}</span>
                {%- endif -%}
              </span>
              <span class="alsel-lp-table-of-contents__arrow" aria-hidden="true">▼</span>
            </a>
          </li>
        {%- endfor -%}
      </ol>
    {%- endif -%}

    {%- if s.footnote != blank -%}
      <p class="alsel-lp-table-of-contents__footnote">{{ s.footnote }}</p>
    {%- endif -%}
  </div>
</section>

<style>
  .alsel-lp-table-of-contents {
    --alsel-lp-toc-bg: {{ s.bg_color }};
    --alsel-lp-toc-accent: {{ s.accent_color }};
    --alsel-lp-toc-sub: {{ s.sub_color }};
    --alsel-lp-toc-text: {{ s.text_color }};
    --alsel-lp-toc-card: {{ s.card_color }};
    background: var(--alsel-lp-toc-bg);
    padding: 2.5rem 1rem;
    color: var(--alsel-lp-toc-text);
  }
  .alsel-lp-table-of-contents__inner {
    max-width: 780px;
    margin: 0 auto;
    background: var(--alsel-lp-toc-card);
    border: 3px solid var(--alsel-lp-toc-accent);
    border-radius: 14px;
    padding: 1.75rem 1.25rem;
    position: relative;
    box-shadow: 0 6px 0 var(--alsel-lp-toc-accent);
  }
  .alsel-lp-table-of-contents__badge {
    display: inline-block;
    background: var(--alsel-lp-toc-accent);
    color: #fff;
    font-weight: 700;
    font-size: 0.85rem;
    padding: 0.35rem 1.1rem;
    border-radius: 9999px;
    position: absolute;
    top: -0.9rem;
    left: 50%;
    transform: translateX(-50%);
    white-space: nowrap;
  }
  .alsel-lp-table-of-contents__heading {
    text-align: center;
    font-size: clamp(1.3rem, 4.5vw, 2rem);
    font-weight: 700;
    margin: 0.5rem 0 0.5rem;
    color: var(--alsel-lp-toc-accent);
    line-height: 1.4;
  }
  .alsel-lp-table-of-contents__heading-mark {
    color: var(--alsel-lp-toc-sub);
    margin: 0 0.4rem;
    font-weight: 700;
  }
  .alsel-lp-table-of-contents__sub {
    text-align: center;
    font-size: 0.95rem;
    line-height: 1.6;
    margin: 0 0 1.5rem;
    color: #444;
  }
  .alsel-lp-table-of-contents__empty {
    text-align: center;
    color: #888;
    padding: 2rem 0;
    margin: 0;
  }
  .alsel-lp-table-of-contents__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.6rem;
  }
  .alsel-lp-table-of-contents__item { margin: 0; }
  .alsel-lp-table-of-contents__link {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 0.85rem;
    background: #fff;
    border: 2px solid var(--alsel-lp-toc-accent);
    border-radius: 10px;
    padding: 0.85rem 1rem;
    text-decoration: none;
    color: var(--alsel-lp-toc-text);
    transition: transform 0.15s ease, background 0.15s ease;
  }
  .alsel-lp-table-of-contents__link:hover {
    background: #fff8e7;
    transform: translateX(2px);
  }
  .alsel-lp-table-of-contents__num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 2.4rem;
    height: 2.4rem;
    padding: 0 0.4rem;
    background: var(--alsel-lp-toc-accent);
    color: #fff;
    font-weight: 700;
    font-size: 1rem;
    border-radius: 50%;
    font-style: italic;
  }
  .alsel-lp-table-of-contents__body {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    min-width: 0;
  }
  .alsel-lp-table-of-contents__title {
    font-weight: 700;
    font-size: 1rem;
    line-height: 1.4;
  }
  .alsel-lp-table-of-contents__note {
    font-size: 0.8rem;
    color: var(--alsel-lp-toc-sub);
    line-height: 1.4;
  }
  .alsel-lp-table-of-contents__arrow {
    color: var(--alsel-lp-toc-accent);
    font-size: 0.9rem;
    font-weight: 700;
  }
  .alsel-lp-table-of-contents__footnote {
    text-align: center;
    font-size: 0.85rem;
    color: #666;
    margin: 1.25rem 0 0;
  }
  @media (min-width: 750px) {
    .alsel-lp-table-of-contents { padding: 4rem 2rem; }
    .alsel-lp-table-of-contents__inner { padding: 2.5rem 2rem; }
    .alsel-lp-table-of-contents__link { padding: 1rem 1.25rem; gap: 1rem; }
    .alsel-lp-table-of-contents__title { font-size: 1.1rem; }
  }
</style>

{% schema %}
