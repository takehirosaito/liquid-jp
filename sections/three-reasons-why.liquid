{% comment %}
============================================================
セクション名: 3つの選ばれる理由
用途: ストアやサービスの強みを 3 つのカードで分かりやすく訴求する定番セクション。初心者の信頼獲得に最適である
推奨設置場所: トップページのファーストビュー直後・商品ページ・LP の中盤
カスタマイズポイント:
  - セクション見出し・サブコピー
  - 各カードのアイコン画像・タイトル・本文
  - 背景色・文字色・アクセントカラー
  - ブロックの追加・削除でカード数を 3〜6 まで変更可能
注意点:
  - アイコンは正方形(推奨 200 × 200px、PNG 透過)で用意する
  - ブロック数は 3 個推奨。それ以上はモバイルで縦並びになる
  - Online Store 2.0 必須(JSON テンプレート対応テーマ)
動作確認バージョン: Online Store 2.0
ライセンス: ALSEL Original
============================================================
{% endcomment %}

<section class="alsel-three-reasons-why" aria-label="{{ section.settings.heading | escape }}">
  <div class="alsel-three-reasons-why__inner">
    {%- if section.settings.eyebrow != blank -%}
      <p class="alsel-three-reasons-why__eyebrow">{{ section.settings.eyebrow | escape }}</p>
    {%- endif -%}
    {%- if section.settings.heading != blank -%}
      <h2 class="alsel-three-reasons-why__heading">{{ section.settings.heading | escape }}</h2>
    {%- endif -%}
    {%- if section.settings.subheading != blank -%}
      <p class="alsel-three-reasons-why__sub">{{ section.settings.subheading | escape }}</p>
    {%- endif -%}

    <div class="alsel-three-reasons-why__grid">
      {%- if section.blocks.size == 0 -%}
    <p class="alsel-three-reasons-why__empty" style="text-align:center;color:#888;padding:2rem 0;">表示する項目をテーマエディタからブロックとして追加してください。</p>
  {%- endif -%}
      {%- for block in section.blocks -%}
        <article class="alsel-three-reasons-why__card" {{ block.shopify_attributes }}>
          <div class="alsel-three-reasons-why__num" aria-hidden="true">
            {{ forloop.index | prepend: '0' | slice: -2, 2 }}
          </div>
          {%- if block.settings.icon != blank -%}
            {%- assign alt_1 = block.settings.title | escape -%}
{{ block.settings.icon
              | image_url: width: 200
              | image_tag:
                loading: 'lazy',
                class: 'alsel-three-reasons-why__icon',
                alt: alt_1,
                widths: '100, 150, 200, 300' }}
          {%- endif -%}
          {%- if block.settings.title != blank -%}
            <h3 class="alsel-three-reasons-why__title">{{ block.settings.title | escape }}</h3>
          {%- endif -%}
          {%- if block.settings.body != blank -%}
            <p class="alsel-three-reasons-why__body">{{ block.settings.body | escape }}</p>
          {%- endif -%}
        </article>
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
  .alsel-three-reasons-why {
    --awh-bg: {{ section.settings.bg_color }};
    --awh-text: {{ section.settings.text_color }};
    --awh-accent: {{ section.settings.accent_color }};
    --awh-card-bg: {{ section.settings.card_bg_color }};
    background: var(--awh-bg);
    color: var(--awh-text);
    padding: 3rem 1rem;
  }
  .alsel-three-reasons-why__inner {
    max-width: 1120px;
    margin: 0 auto;
  }
  .alsel-three-reasons-why__eyebrow {
    text-align: center;
    font-size: 0.85rem;
    letter-spacing: 0.15em;
    color: var(--awh-accent);
    margin: 0 0 0.75rem;
    font-weight: 700;
  }
  .alsel-three-reasons-why__heading {
    text-align: center;
    font-size: clamp(1.5rem, 4.5vw, 2.4rem);
    font-weight: 700;
    line-height: 1.4;
    margin: 0 0 0.75rem;
  }
  .alsel-three-reasons-why__sub {
    text-align: center;
    font-size: 0.95rem;
    line-height: 1.7;
    margin: 0 auto 2.5rem;
    max-width: 640px;
    opacity: 0.8;
  }
  .alsel-three-reasons-why__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }
  .alsel-three-reasons-why__card {
    position: relative;
    background: var(--awh-card-bg);
    border-radius: 16px;
    padding: 2.25rem 1.5rem 1.75rem;
    text-align: center;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.06);
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }
  .alsel-three-reasons-why__card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 28px rgba(0, 0, 0, 0.1);
  }
  .alsel-three-reasons-why__num {
    position: absolute;
    top: -0.5rem;
    left: 50%;
    transform: translateX(-50%);
    background: var(--awh-accent);
    color: #fff;
    font-weight: 700;
    font-size: 0.85rem;
    padding: 0.3rem 0.9rem;
    border-radius: 9999px;
    letter-spacing: 0.05em;
  }
  .alsel-three-reasons-why__icon {
    width: 88px;
    height: 88px;
    object-fit: contain;
    margin: 0.5rem auto 1rem;
    display: block;
  }
  .alsel-three-reasons-why__title {
    font-size: 1.15rem;
    font-weight: 700;
    line-height: 1.5;
    margin: 0 0 0.75rem;
    color: var(--awh-text);
  }
  .alsel-three-reasons-why__body {
    font-size: 0.95rem;
    line-height: 1.8;
    margin: 0;
    color: var(--awh-text);
    opacity: 0.85;
  }
  @media (min-width: 750px) {
    .alsel-three-reasons-why {
      padding: 5rem 2rem;
    }
    .alsel-three-reasons-why__grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 1.75rem;
    }
    .alsel-three-reasons-why__card {
      padding: 2.5rem 1.75rem 2rem;
    }
    .alsel-three-reasons-why__icon {
      width: 104px;
      height: 104px;
    }
  }
</style>

{% schema %}
{
  "name": "3つの選ばれる理由",
  "tag": "section",
  "class": "alsel-section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "上部の小見出し", "default": "REASONS", "info": "見出しの上に表示する英字や短い言葉" },
    { "type": "text", "id": "heading", "label": "セクション見出し", "default": "選ばれる3つの理由" },
    { "type": "textarea", "id": "subheading", "label": "サブコピー", "default": "お客様に選ばれ続ける、当店の強みをご紹介します。" },
    { "type": "color", "id": "bg_color", "label": "背景色", "default": "#f8fafc" },
    { "type": "color", "id": "card_bg_color", "label": "カード背景色", "default": "#ffffff" },
    { "type": "color", "id": "text_color", "label": "文字色", "default": "#1e293b" },
    { "type": "color", "id": "accent_color", "label": "アクセントカラー", "default": "#6d28d9", "info": "番号バッジや小見出しに使われる色" }
  ],
  "blocks": [
    {
      "type": "reason",
      "name": "理由カード",
      "limit": 6,
      "settings": [
        { "type": "image_picker", "id": "icon", "label": "アイコン画像", "info": "推奨 200 × 200px、PNG 透過推奨" },
        { "type": "text", "id": "title", "label": "タイトル", "default": "ポイント名" },
        { "type": "textarea", "id": "body", "label": "本文", "default": "理由の説明文をここに入れる。お客様目線で具体的に書くと効果的である。" }
      ]
    }
  ],
  "presets": [
    {
      "name": "ALSEL監修 / 3つの選ばれる理由",
      "settings": {
        "eyebrow": "REASONS",
        "heading": "選ばれる3つの理由",
        "subheading": "お客様に選ばれ続ける、当店の強みをご紹介します。"
      },
      "blocks": [
        { "type": "reason", "settings": { "title": "高品質な素材", "body": "厳選した素材だけを使い、丁寧に仕上げている。" } },
        { "type": "reason", "settings": { "title": "送料無料", "body": "5,000 円以上のご注文で全国どこでも送料無料である。" } },
        { "type": "reason", "settings": { "title": "安心の返品保証", "body": "ご購入から 30 日以内であれば返品・交換に対応します。" } }
      ]
    }
  ]
}
{% endschema %}